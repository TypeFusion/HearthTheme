    "tokenColors": [
        {
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#6b5f4d",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "keyword",
                "storage.type",
                "storage.modifier",
                "keyword.control"
            ],
            "settings": {
                "foreground": "#d0653b",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "keyword.operator",
                "keyword.operator.assignment"
            ],
            "settings": {
                "foreground": "#a8824e",
                "fontStyle": ""
            }
        },
        {
            "scope": [
                "entity.name.function",
                "support.function",
                "meta.function-call.generic"
            ],
            "settings": {
                "foreground": "#ddb06a"
            }
        },
        {
            "scope": [
                "string",
                "string.quoted",
                "string.template",
                "string.regexp"
            ],
            "settings": {
                "foreground": "#87ab70"
            }
        },
        {
            "scope": [
                "constant.numeric",
                "constant.language.boolean",
                "constant.language.null",
                "constant.language.undefined"
            ],
            "settings": {
                "foreground": "#c66a52"
            }
        },
        {
            "scope": [
                "entity.name.type",
                "entity.name.class",
                "support.type",
                "support.class"
            ],
            "settings": {
                "foreground": "#79a8a2",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "variable",
                "variable.other.readwrite"
            ],
            "settings": {
                "foreground": "#c1b59f"
            }
        },
        {
            "scope": [
                "variable.other.property",
                "support.type.property-name",
                "meta.object-literal.key"
            ],
            "settings": {
                "foreground": "#ba9560"
            }
        },
        {
            "scope": [
                "entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#c3a270"
            }
        },
        {
            "scope": [
                "entity.name.tag",
                "punctuation.definition.tag"
            ],
            "settings": {
                "foreground": "#d97343"
            }
        },
        {
            "scope": [
                "meta.decorator",
                "punctuation.decorator"
            ],
            "settings": {
                "foreground": "#d4b283",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "punctuation",
                "meta.brace"
            ],
            "settings": {
                "foreground": "#91826b"
            }
        },
        {
            "scope": [
                "constant.other.color",
                "support.constant"
            ],
            "settings": {
                "foreground": "#c66a52"
            }
        },
        {
            "scope": [
                "markup.heading"
            ],
            "settings": {
                "foreground": "#ddb06a",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "markup.bold"
            ],
            "settings": {
                "foreground": "#d0653b",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "markup.italic"
            ],
            "settings": {
                "foreground": "#c3a270",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "markup.inline.raw",
                "markup.fenced_code"
            ],
            "settings": {
                "foreground": "#87ab70"
            }
        },
        {
            "scope": [
                "markup.underline.link"
            ],
            "settings": {
                "foreground": "#87ab70"
            }
        },
        {
            "scope": [
                "invalid.deprecated"
            ],
            "settings": {
                "foreground": "#c66a52",
                "fontStyle": "strikethrough"
            }
        },
        {
            "scope": [
                "invalid.illegal"
            ],
            "settings": {
                "foreground": "#c66a52",
                "fontStyle": "underline"
            }
        }
    ],
    "semanticHighlighting": true,
    "semanticTokenColors": {
        "variable": "#c1b59f",
        "variable.readonly": "#c3a270",
        "property": "#ba9560",
        "property.readonly": "#c3a270",
        "function": "#ddb06a",
        "method": "#ddb06a",
        "class": {
            "foreground": "#79a8a2",
            "fontStyle": "italic"
        },
        "interface": {
            "foreground": "#79a8a2",
            "fontStyle": "italic"
        },
        "type": {
            "foreground": "#79a8a2",
            "fontStyle": "italic"
        },
        "typeParameter": {
            "foreground": "#79a8a2",
            "fontStyle": "italic"
        },
        "enum": {
            "foreground": "#79a8a2",
            "fontStyle": "italic"
        },
        "enumMember": "#c66a52",
        "namespace": "#d6cab4",
        "keyword": {
            "foreground": "#d0653b",
            "fontStyle": "bold"
        },
        "parameter": "#c1b59f",
        "decorator": {
            "foreground": "#d4b283",
            "fontStyle": "italic"
        }
    }
}
