        "gitDecoration.ignoredResourceForeground": "#c0aa88",
        "gitDecoration.conflictingResourceForeground": "#c9833a"
    },
    "tokenColors": [
        {
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#9a8868",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "keyword",
                "storage.type",
                "storage.modifier",
                "keyword.control"
            ],
            "settings": {
                "foreground": "#8a3000",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "keyword.operator",
                "keyword.operator.assignment"
            ],
            "settings": {
                "foreground": "#906040",
                "fontStyle": ""
            }
        },
        {
            "scope": [
                "entity.name.function",
                "support.function",
                "meta.function-call.generic"
            ],
            "settings": {
                "foreground": "#684000"
            }
        },
        {
            "scope": [
                "string",
                "string.quoted",
                "string.template",
                "string.regexp"
            ],
            "settings": {
                "foreground": "#385820"
            }
        },
        {
            "scope": [
                "constant.numeric",
                "constant.language.boolean",
                "constant.language.null"
            ],
            "settings": {
                "foreground": "#963820"
            }
        },
        {
            "scope": [
                "entity.name.type",
                "entity.name.class",
                "support.type",
                "support.class"
            ],
            "settings": {
                "foreground": "#784418",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "variable",
                "variable.other.readwrite"
            ],
            "settings": {
                "foreground": "#3a2c18"
            }
        },
        {
            "scope": [
                "variable.other.property",
                "support.type.property-name",
                "meta.object-literal.key"
            ],
            "settings": {
                "foreground": "#5a3c18"
            }
        },
        {
            "scope": [
                "entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#784418"
            }
        },
        {
            "scope": [
                "entity.name.tag",
                "punctuation.definition.tag"
            ],
            "settings": {
                "foreground": "#8a3000"
            }
        },
        {
            "scope": [
                "meta.decorator",
                "punctuation.decorator"
            ],
            "settings": {
                "foreground": "#684000",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "punctuation",
                "meta.brace"
            ],
            "settings": {
                "foreground": "#8a7060"
            }
        },
        {
            "scope": [
                "markup.heading"
            ],
            "settings": {
                "foreground": "#684000",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "markup.bold"
            ],
            "settings": {
                "foreground": "#8a3000",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "markup.italic"
            ],
            "settings": {
                "foreground": "#784418",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "markup.inline.raw",
                "markup.fenced_code"
            ],
            "settings": {
                "foreground": "#385820"
            }
        },
        {
            "scope": [
                "markup.underline.link"
            ],
            "settings": {
                "foreground": "#385820"
            }
        },
        {
            "scope": [
                "invalid.deprecated"
            ],
            "settings": {
                "foreground": "#903020",
                "fontStyle": "strikethrough"
            }
        },
        {
            "scope": [
                "invalid.illegal"
            ],
            "settings": {
                "foreground": "#903020",
                "fontStyle": "underline"
            }
        }
    ],
    "semanticHighlighting": true,
    "semanticTokenColors": {
        "variable": "#3a2c18",
        "variable.readonly": "#784418",
        "property": "#5a3c18",
        "property.readonly": "#784418",
        "function": "#684000",
        "method": "#684000",
        "class": {
            "foreground": "#784418",
            "fontStyle": "italic"
        },
        "interface": {
            "foreground": "#784418",
            "fontStyle": "italic"
        },
        "type": {
            "foreground": "#784418",
            "fontStyle": "italic"
        },
        "typeParameter": {
            "foreground": "#784418",
            "fontStyle": "italic"
        },
        "enum": {
            "foreground": "#784418",
            "fontStyle": "italic"
        },
        "enumMember": "#963820",
        "namespace": "#2c1c08",
        "keyword": {
            "foreground": "#8a3000",
            "fontStyle": "bold"
        },
        "parameter": "#3a2c18",
        "decorator": {
            "foreground": "#684000",
            "fontStyle": "italic"
        }
    }
}