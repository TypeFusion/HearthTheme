---
import { t, type Lang } from '../../i18n/utils'
import { productData } from '../../data/product'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const marketplaceUrl = productData.links.marketplaceUrl
const openVsxUrl = productData.links.openVsxUrl
const obsidianUrl = productData.links.releasesUrl

const options = [
  {
    href: marketplaceUrl,
    external: true,
    titleKey: 'final.option.vscode.title',
    bodyKey: 'final.option.vscode.body',
    ctaKey: 'hero.cta.install',
  },
  {
    href: openVsxUrl,
    external: true,
    titleKey: 'final.option.openvsx.title',
    bodyKey: 'final.option.openvsx.body',
    ctaKey: 'hero.cta.openvsx',
  },
  {
    href: obsidianUrl,
    external: true,
    titleKey: 'final.option.obsidian.title',
    bodyKey: 'final.option.obsidian.body',
    ctaKey: 'hero.cta.obsidian',
  },
]
---

<section id="get-started" class="hearth-section hearth-tail-wrap">
  <div class="hearth-shell">
    <div data-reveal class="hearth-tail-content">
      <p class="hearth-kicker hearth-kicker-accent mb-4 flex items-center gap-3">
        {t(lang, 'final.label')}
        <span class="hearth-line"></span>
      </p>

      <h2 class="hearth-heading-strong text-[1.7rem] sm:text-[2.1rem] leading-[1.15] tracking-[-0.015em] font-semibold mb-3">
        {t(lang, 'final.title')}
      </h2>

      {t(lang, 'final.subtitle') ? (
        <p class="hearth-copy hearth-copy-muted max-w-[60ch] mb-7">
          {t(lang, 'final.subtitle')}
        </p>
      ) : null}

      <div class="final-option-grid mb-6">
        {options.map(({ href, external, titleKey, bodyKey, ctaKey }) => (
          <a
            href={href}
            target={external ? '_blank' : undefined}
            rel={external ? 'noopener noreferrer' : undefined}
            class="final-option-card"
          >
            <div>
              <h3 class="final-option-title">{t(lang, titleKey)}</h3>
              <p class="final-option-body">{t(lang, bodyKey)}</p>
            </div>
            <span class="final-option-cta">
              <span>{t(lang, ctaKey)}</span>
              <span aria-hidden="true">{external ? '↗' : '→'}</span>
            </span>
          </a>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
  .final-option-grid {
    display: grid;
    gap: 0.9rem;
  }

  .final-option-card {
    display: grid;
    gap: 0.9rem;
    align-items: start;
    border: 1px solid var(--hearth-card-border);
    border-radius: 22px;
    padding: 1rem 1.05rem;
    text-decoration: none;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--hearth-panel) 88%, transparent), var(--hearth-panel-soft)),
      radial-gradient(circle at top left, var(--hearth-glow-soft), transparent 58%);
    box-shadow:
      0 16px 34px var(--hearth-shadow-016),
      inset 0 1px 0 var(--hearth-paper-grid-soft);
    transition:
      transform 180ms var(--hearth-ease),
      border-color 220ms var(--hearth-ease),
      box-shadow 220ms var(--hearth-ease);
  }

  .final-option-card:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--hearth-ember) 28%, var(--hearth-card-border));
  }

  .final-option-title {
    margin: 0 0 0.38rem;
    color: var(--hearth-ink-strong);
    font-family: var(--font-ui);
    font-size: 1rem;
    font-weight: 600;
  }

  .final-option-body {
    margin: 0;
    color: var(--hearth-ink-soft);
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .final-option-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--hearth-ink-strong);
    font-family: var(--font-ui);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  @media (min-width: 860px) {
    .final-option-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
