---
import { t, type Lang } from '../../i18n/utils'
import CodePreview from '../code/CodePreview.astro'
import { productData } from '../../data/product'
import { getDefaultThemeSelection, themePaletteCatalog, type ThemePaletteTheme } from '../../lib/themeFit'

interface Props {
  lang: Lang
}

const { lang } = Astro.props

function escapeJsonForScript(value: unknown): string {
  return JSON.stringify(value).replace(/</g, '\\u003c')
}

function localize(lang: Lang, key: string, fallback: string): string {
  const value = t(lang, key)
  return value === key ? fallback : value
}

function paletteStyle(theme: ThemePaletteTheme): string {
  const swatches = Object.fromEntries(theme.swatches.map((swatch) => [swatch.id, swatch.color]))
  return [
    `--pick-surface:${theme.surface}`,
    `--pick-ink:${theme.foreground}`,
    `--pick-accent:${theme.accent}`,
    `--pick-keyword:${swatches.keyword ?? theme.accent}`,
    `--pick-function:${swatches.function ?? theme.foreground}`,
    `--pick-property:${swatches.property ?? theme.foreground}`,
    `--pick-type:${swatches.type ?? theme.foreground}`,
  ].join(';')
}

const installUrl = '#get-started'
const heroTitle = productData.product.wordmark.full
const defaultSelection = getDefaultThemeSelection()

const themes = themePaletteCatalog.map((theme) => ({
  id: theme.themeId,
  schemeId: theme.schemeId,
  variantId: theme.variantId,
  label: theme.label,
  summary: localize(lang, `fit.theme.${theme.themeId}.summary`, theme.summary),
  surface: theme.surface,
  foreground: theme.foreground,
  accent: theme.accent,
  swatches: theme.swatches,
  isDefault: theme.isDefault,
  isPublished: true,
}))

const flavors = productData.flavors
  .filter((flavor) => flavor.isPublished)
  .map((flavor) => {
    const representativeTheme =
      themes.find((theme) => theme.schemeId === flavor.id && theme.variantId === flavor.defaultVariant) ||
      themes.find((theme) => theme.schemeId === flavor.id) ||
      themes[0]

    return {
      id: flavor.id,
      label: flavor.shortName,
      summary: localize(lang, `fit.flavor.${flavor.id}.summary`, flavor.summary),
      representativeThemeId: representativeTheme.id,
      defaultVariantId: representativeTheme.variantId,
    }
  })

const variants = Array.from(
  new Map(
    productData.extension.themeCatalog.map((theme) => [
      theme.variantId,
      {
        id: theme.variantId,
        label: localize(lang, `fit.climate.${theme.variantId}.label`, theme.climateLabel),
        summary: localize(lang, `fit.climate.${theme.variantId}.summary`, theme.climateLabel),
      },
    ]),
  ).values(),
)

const initialTheme =
  themes.find((theme) => theme.id === defaultSelection.themeId) ||
  themes.find((theme) => theme.isDefault) ||
  themes[0]

const pickerData = {
  defaultSelection: {
    ...defaultSelection,
    flavorId: initialTheme.schemeId,
    variantId: initialTheme.variantId,
  },
  installUrl,
  colorSystemUrl: '#color-system',
  themes,
  flavors,
  variants,
  copy: {
    installCta: t(lang, 'hero.quick.install'),
    previewCta: t(lang, 'hero.cta.system'),
  },
}

const pickerDataJson = escapeJsonForScript(pickerData)
---

<section id="theme-picker" class="hearth-section hearth-hero-section pt-6 sm:pt-8 pb-12 sm:pb-16" data-reveal>
  <div class="hearth-shell">
    <div class="hero-grid">
      <div class="hero-copy">
        <h1 class="hero-title mb-3">{heroTitle}</h1>
        <p class="hero-subtitle hearth-copy hearth-copy-soft mb-6">
          {t(lang, 'hero.subtitle')}
        </p>

        <div
          class="hero-picker"
          data-hero-picker
          data-default-theme={defaultSelection.themeId}
        >
          <script type="application/json" data-hero-catalog set:html={pickerDataJson}></script>

          <div class="hero-picker-group">
            <div class="hero-picker-group-head">
              <div class="hero-picker-group-copy">
                <strong>{t(lang, 'hero.quick.flavor')}</strong>
              </div>
            </div>

            <div class="hero-flavor-grid">
              {flavors.map((flavor) => {
                const theme = themes.find((entry) => entry.id === flavor.representativeThemeId) || initialTheme
                return (
                  <button
                    type="button"
                    class={`hero-flavor-card ${flavor.id === initialTheme.schemeId ? 'is-active' : ''}`}
                    data-hero-flavor
                    data-flavor-id={flavor.id}
                    aria-pressed={flavor.id === initialTheme.schemeId ? 'true' : 'false'}
                    style={paletteStyle(theme)}
                  >
                    <div class="hero-flavor-top">
                      <strong class="hero-flavor-name">{flavor.label}</strong>
                    </div>
                    <div class="hero-flavor-preview" aria-hidden="true">
                      <span class="hero-flavor-line hero-flavor-line--keyword"></span>
                      <span class="hero-flavor-line hero-flavor-line--function"></span>
                    </div>
                    <p class="hero-flavor-summary">{flavor.summary}</p>
                  </button>
                )
              })}
            </div>
          </div>

          <div class="hero-picker-group">
            <div class="hero-picker-group-head">
              <div class="hero-picker-group-copy">
                <strong>{t(lang, 'hero.quick.climate')}</strong>
              </div>
            </div>

            <div class="hero-climate-row">
              {variants.map((variant) => {
                const theme =
                  themes.find((entry) => entry.schemeId === initialTheme.schemeId && entry.variantId === variant.id) ||
                  initialTheme
                return (
                  <button
                    type="button"
                    class={`hero-climate-pill ${variant.id === initialTheme.variantId ? 'is-active' : ''}`}
                    data-hero-variant
                    data-variant-id={variant.id}
                    data-climate-id={variant.id}
                    aria-pressed={variant.id === initialTheme.variantId ? 'true' : 'false'}
                    style={paletteStyle(theme)}
                  >
                    <div class="hero-climate-preview" aria-hidden="true">
                      <span class="hero-climate-preview-top"></span>
                      <div class="hero-climate-preview-body">
                        <span class="hero-climate-preview-line hero-climate-preview-line--soft"></span>
                        <span class="hero-climate-preview-line hero-climate-preview-line--strong"></span>
                      </div>
                    </div>
                    <span class="hero-climate-pill-label">{variant.label}</span>
                  </button>
                )
              })}
            </div>
          </div>

          <div class="hero-current" data-hero-current style={paletteStyle(initialTheme)}>
            <div class="hero-current-top">
              <h2 class="hero-current-title" data-hero-title>{initialTheme.label}</h2>
            </div>

            <div class="hero-current-copy">
              <p class="hero-current-body" data-hero-body>{initialTheme.summary}</p>
            </div>

            <div class="hero-current-actions">
              <a
                href={initialTheme.isPublished ? installUrl : '#color-system'}
                class="hearth-btn-primary hero-action"
                data-hero-primary
              >
                {initialTheme.isPublished ? t(lang, 'hero.quick.install') : t(lang, 'hero.cta.system')}
              </a>
            </div>
          </div>
        </div>
      </div>

      <div class="hero-preview">
        <CodePreview lang={lang} compact={true} />
      </div>
    </div>
  </div>
</section>

<style>
  .hearth-hero-section {
    position: relative;
  }

  .hero-grid {
    display: grid;
    gap: 1.4rem;
    align-items: start;
  }

  .hero-copy {
    min-width: 0;
  }

  .hero-title {
    margin: 0;
    color: var(--hearth-ink-strong);
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 7vw, 5.2rem);
    line-height: 0.94;
    letter-spacing: -0.05em;
  }

  .hero-subtitle {
    max-width: 34rem;
    font-size: 1rem;
    line-height: 1.78;
  }

  .hero-picker {
    position: relative;
    display: grid;
    gap: 1rem;
    border: 1px solid color-mix(in srgb, var(--hearth-ember) 16%, var(--hearth-card-border));
    border-radius: 28px;
    padding: 1rem;
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--hearth-panel) 97%, black 3%),
        color-mix(in srgb, var(--hearth-panel-soft) 94%, black 6%)
      ),
      radial-gradient(circle at top left, color-mix(in srgb, var(--hearth-glow-soft) 92%, transparent), transparent 58%);
    box-shadow:
      0 32px 68px var(--hearth-shadow-016),
      0 0 0 1px color-mix(in srgb, var(--hearth-paper-grid-soft) 40%, transparent),
      inset 0 1px 0 color-mix(in srgb, var(--hearth-paper-grid-soft) 88%, transparent);
  }

  .hero-picker::before {
    content: "";
    position: absolute;
    inset: 0.65rem;
    border-radius: 20px;
    border: 1px solid color-mix(in srgb, var(--hearth-card-border) 62%, transparent);
    pointer-events: none;
    opacity: 0.8;
  }

  .hero-picker-group,
  .hero-current {
    border-radius: 22px;
    border: 1px solid color-mix(in srgb, var(--hearth-card-border) 96%, transparent);
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--hearth-panel-soft) 94%, black 6%),
        color-mix(in srgb, var(--hearth-panel) 78%, transparent)
      ),
      radial-gradient(circle at top left, color-mix(in srgb, var(--hearth-glow-soft) 72%, transparent), transparent 64%);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--hearth-paper-grid-soft) 72%, transparent),
      0 16px 28px color-mix(in srgb, var(--hearth-shadow-016) 76%, transparent);
  }

  .hero-picker-group {
    position: relative;
    padding: 0.95rem 1rem 1rem;
    display: grid;
    gap: 0.9rem;
    border-color: color-mix(in srgb, var(--hearth-ember) 18%, var(--hearth-card-border));
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--hearth-paper-grid-soft) 76%, transparent),
      0 18px 30px color-mix(in srgb, var(--hearth-shadow-016) 52%, transparent);
  }

  .hero-picker-group-head {
    display: block;
  }

  .hero-picker-group-copy {
    display: flex;
    align-items: center;
  }

  .hero-picker-group-copy strong {
    color: var(--hearth-ink-strong);
    font-family: var(--font-ui);
    font-size: 0.96rem;
    font-weight: 600;
  }

  .hero-flavor-grid {
    display: grid;
    gap: 0.8rem;
  }

  .hero-flavor-card,
  .hero-climate-pill {
    position: relative;
    overflow: hidden;
    cursor: pointer;
    width: 100%;
    text-align: left;
    transition:
      transform 180ms var(--hearth-ease),
      border-color 220ms var(--hearth-ease),
      background-color 220ms var(--hearth-ease),
      box-shadow 220ms var(--hearth-ease);
  }

  .hero-flavor-card {
    display: grid;
    gap: 0.75rem;
    padding: 0.9rem;
    border-radius: 20px;
    border: 1px solid color-mix(in srgb, var(--hearth-card-border) 96%, transparent);
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--hearth-panel-soft) 92%, black 8%),
        color-mix(in srgb, var(--hearth-panel) 90%, black 10%)
      ),
      radial-gradient(circle at top left, color-mix(in srgb, var(--hearth-glow-soft) 38%, transparent), transparent 62%);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--pick-ink) 8%, transparent),
      0 12px 22px color-mix(in srgb, var(--hearth-shadow-016) 48%, transparent);
  }

  .hero-flavor-card::before,
  .hero-climate-pill::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--hearth-paper-grid-soft) 22%, transparent),
      transparent 42%
    );
    opacity: 0;
    transition:
      opacity 220ms var(--hearth-ease),
      opacity 220ms var(--hearth-ease);
    pointer-events: none;
  }

  .hero-flavor-card:hover,
  .hero-climate-pill:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--hearth-ember) 34%, var(--hearth-card-border));
    box-shadow:
      0 18px 30px color-mix(in srgb, var(--hearth-shadow-016) 72%, transparent),
      inset 0 0 0 1px color-mix(in srgb, var(--hearth-ember) 10%, transparent);
  }

  .hero-flavor-card:hover::before,
  .hero-climate-pill:hover::before {
    opacity: 1;
  }

  .hero-flavor-card.is-active,
  .hero-climate-pill.is-active {
    border-color: color-mix(in srgb, var(--hearth-ember) 54%, var(--hearth-card-border));
    box-shadow:
      0 20px 34px var(--hearth-shadow-016),
      0 0 0 1px color-mix(in srgb, var(--hearth-ember) 12%, transparent),
      inset 0 0 0 1px color-mix(in srgb, var(--hearth-ember) 22%, transparent);
  }

  .hero-flavor-card.is-active::before,
  .hero-climate-pill.is-active::before {
    opacity: 1;
  }

  .hero-flavor-top,
  .hero-current-top {
    display: flex;
    align-items: start;
    gap: 0.7rem;
  }

  .hero-flavor-name,
  .hero-current-title {
    color: var(--hearth-ink-strong);
    font-family: var(--font-ui);
    font-weight: 700;
  }

  .hero-flavor-name {
    font-size: 1rem;
  }

  .hero-flavor-preview {
    display: grid;
    gap: 0.45rem;
    padding: 0.78rem;
    border-radius: 16px;
    border: 1px solid color-mix(in srgb, var(--hearth-card-border) 92%, transparent);
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--hearth-panel-soft) 94%, var(--pick-surface) 6%),
        color-mix(in srgb, var(--hearth-panel) 92%, var(--pick-surface) 8%)
      ),
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--hearth-paper-grid-soft) 12%, transparent),
        transparent 54%
      );
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--hearth-paper-grid-soft) 58%, transparent),
      inset 0 0 0 1px color-mix(in srgb, var(--pick-ink) 4%, transparent);
  }

  .hero-flavor-line {
    display: block;
    height: 0.36rem;
    border-radius: 9999px;
  }

  .hero-flavor-line--keyword {
    width: 72%;
    background: var(--pick-keyword);
  }

  .hero-flavor-line--function {
    width: 56%;
    background: var(--pick-function);
  }

  .hero-flavor-summary {
    margin: 0;
    color: var(--hearth-ink-soft);
    font-size: 0.92rem;
    line-height: 1.62;
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-clamp: 2;
  }

  .hero-climate-row {
    display: grid;
    gap: 0.7rem;
  }

  .hero-climate-pill {
    --climate-preview-start: color-mix(in srgb, var(--pick-surface) 96%, white 4%);
    --climate-preview-end: color-mix(in srgb, var(--pick-surface) 90%, black 10%);
    --climate-preview-border: color-mix(in srgb, var(--pick-ink) 12%, var(--hearth-card-border));
    --climate-preview-sheen: color-mix(in srgb, white 12%, transparent);
    --climate-topline: color-mix(in srgb, var(--pick-ink) 24%, var(--pick-surface));
    --climate-line-soft: color-mix(in srgb, var(--pick-ink) 28%, var(--pick-surface));
    --climate-line-strong: color-mix(in srgb, var(--pick-ink) 46%, var(--pick-surface));
    display: grid;
    gap: 0.6rem;
    padding: 0.78rem;
    align-content: start;
    border-radius: 16px;
    border: 1px solid color-mix(in srgb, var(--hearth-card-border) 96%, transparent);
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--hearth-panel-soft) 94%, black 6%),
        color-mix(in srgb, var(--hearth-panel) 92%, black 8%)
      ),
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--hearth-paper-grid-soft) 10%, transparent),
        transparent 54%
      );
    color: var(--hearth-ink-strong);
    font-family: var(--font-ui);
    font-size: 0.92rem;
    font-weight: 600;
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--hearth-paper-grid-soft) 58%, transparent),
      0 10px 18px color-mix(in srgb, var(--hearth-shadow-016) 34%, transparent);
  }

  .hero-climate-pill[data-climate-id='dark'] {
    --climate-preview-start: color-mix(in srgb, var(--pick-surface) 94%, white 6%);
    --climate-preview-end: color-mix(in srgb, var(--pick-surface) 88%, black 12%);
    --climate-preview-border: color-mix(in srgb, var(--pick-ink) 16%, var(--hearth-card-border));
    --climate-preview-sheen: color-mix(in srgb, white 12%, transparent);
    --climate-topline: color-mix(in srgb, var(--pick-ink) 24%, var(--pick-surface));
    --climate-line-soft: color-mix(in srgb, var(--pick-ink) 28%, var(--pick-surface));
    --climate-line-strong: color-mix(in srgb, var(--pick-ink) 54%, var(--pick-surface));
  }

  .hero-climate-pill[data-climate-id='darkSoft'] {
    --climate-preview-start: color-mix(in srgb, var(--pick-surface) 96%, white 4%);
    --climate-preview-end: color-mix(in srgb, var(--pick-surface) 92%, black 8%);
    --climate-preview-border: color-mix(in srgb, var(--pick-ink) 10%, var(--hearth-card-border));
    --climate-preview-sheen: color-mix(in srgb, white 8%, transparent);
    --climate-topline: color-mix(in srgb, var(--pick-ink) 16%, var(--pick-surface));
    --climate-line-soft: color-mix(in srgb, var(--pick-ink) 18%, var(--pick-surface));
    --climate-line-strong: color-mix(in srgb, var(--pick-ink) 34%, var(--pick-surface));
  }

  .hero-climate-pill[data-climate-id='light'] {
    --climate-preview-start: color-mix(in srgb, var(--pick-surface) 98%, white 2%);
    --climate-preview-end: color-mix(in srgb, var(--pick-surface) 94%, black 6%);
    --climate-preview-border: color-mix(in srgb, var(--pick-ink) 14%, var(--hearth-card-border));
    --climate-preview-sheen: color-mix(in srgb, white 22%, transparent);
    --climate-topline: color-mix(in srgb, var(--pick-ink) 18%, var(--pick-surface));
    --climate-line-soft: color-mix(in srgb, var(--pick-ink) 26%, var(--pick-surface));
    --climate-line-strong: color-mix(in srgb, var(--pick-ink) 58%, var(--pick-surface));
  }

  .hero-climate-pill[data-climate-id='lightSoft'] {
    --climate-preview-start: color-mix(in srgb, var(--pick-surface) 97%, white 3%);
    --climate-preview-end: color-mix(in srgb, var(--pick-surface) 92%, black 8%);
    --climate-preview-border: color-mix(in srgb, var(--pick-ink) 10%, var(--hearth-card-border));
    --climate-preview-sheen: color-mix(in srgb, white 16%, transparent);
    --climate-topline: color-mix(in srgb, var(--pick-ink) 14%, var(--pick-surface));
    --climate-line-soft: color-mix(in srgb, var(--pick-ink) 20%, var(--pick-surface));
    --climate-line-strong: color-mix(in srgb, var(--pick-ink) 38%, var(--pick-surface));
  }

  .hero-climate-preview {
    display: grid;
    gap: 0.5rem;
    padding: 0.72rem;
    min-height: 4.2rem;
    border-radius: 14px;
    border: 1px solid var(--climate-preview-border);
    background:
      linear-gradient(
        180deg,
        var(--climate-preview-start),
        var(--climate-preview-end)
      ),
      linear-gradient(
        180deg,
        var(--climate-preview-sheen),
        transparent 46%
      );
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, white 16%, transparent),
      inset 0 0 0 1px color-mix(in srgb, var(--pick-ink) 4%, transparent);
  }

  .hero-climate-preview-top {
    display: block;
    width: 38%;
    height: 0.32rem;
    border-radius: 9999px;
    background: var(--climate-topline);
  }

  .hero-climate-preview-body {
    display: grid;
    gap: 0.42rem;
  }

  .hero-climate-preview-line {
    display: block;
    height: 0.5rem;
    border-radius: 9999px;
  }

  .hero-climate-preview-line--soft {
    width: 76%;
    background: var(--climate-line-soft);
  }

  .hero-climate-preview-line--strong {
    width: 58%;
    background: var(--climate-line-strong);
  }

  .hero-climate-pill-label {
    color: var(--hearth-ink-soft);
    font-family: var(--font-ui);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .hero-current {
    display: grid;
    gap: 0.9rem;
    padding: 1.05rem;
    border-color: color-mix(in srgb, var(--hearth-ember) 14%, var(--hearth-card-border));
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--hearth-panel-soft) 95%, black 5%),
        color-mix(in srgb, var(--hearth-panel) 90%, black 10%)
      ),
      radial-gradient(circle at top left, color-mix(in srgb, var(--hearth-glow-soft) 48%, transparent), transparent 62%);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--hearth-paper-grid-soft) 64%, transparent),
      0 18px 30px color-mix(in srgb, var(--hearth-shadow-016) 72%, transparent);
  }

  .hero-current-copy {
    min-width: 0;
  }

  .hero-current-title {
    margin: 0;
    font-size: 1.28rem;
    line-height: 1.08;
    letter-spacing: -0.02em;
  }

  .hero-current-body {
    margin: 0.45rem 0 0;
    color: var(--hearth-ink-soft);
    font-size: 0.93rem;
    line-height: 1.62;
    max-width: 34ch;
  }

  .hero-current-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 0.1rem;
  }

  .hero-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.8rem;
    padding: 0.72rem 1rem;
    border: 1px solid transparent;
    border-radius: 9999px;
    font-family: var(--font-ui);
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1;
    text-decoration: none;
    transition:
      transform 180ms var(--hearth-ease),
      border-color 220ms var(--hearth-ease),
      box-shadow 220ms var(--hearth-ease),
      color 220ms var(--hearth-ease);
  }

  .hero-action:hover {
    transform: translateY(-1px);
  }

  .hero-preview {
    min-width: 0;
  }

  @media (min-width: 861px) {
    .hero-grid {
      grid-template-columns: minmax(0, 1.02fr) minmax(420px, 0.98fr);
      gap: 1.6rem;
      align-items: center;
    }

    .hero-flavor-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .hero-climate-row {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 860px) {
    .hero-subtitle {
      max-width: 100%;
    }
  }

  @media (max-width: 560px) {
    .hero-picker {
      padding: 0.85rem;
      border-radius: 24px;
    }

    .hero-picker-group,
    .hero-current,
    .hero-flavor-card,
    .hero-climate-pill {
      border-radius: 18px;
    }

    .hero-picker-group,
    .hero-current {
      padding-inline: 0.9rem;
    }

    .hero-flavor-card,
    .hero-climate-pill {
      padding: 0.82rem;
    }
  }
</style>

<script>
  document.querySelectorAll('[data-hero-picker]').forEach((root) => {
    type SwatchId = 'surface' | 'keyword' | 'function' | 'property' | 'type'

    type ThemeData = {
      id: string
      schemeId: string
      variantId: string
      label: string
      summary: string
      isPublished: boolean
      surface: string
      foreground: string
      accent: string
      swatches: Array<{ id: SwatchId; color: string }>
    }

    type FlavorData = {
      id: string
      label: string
      summary: string
      representativeThemeId: string
      defaultVariantId: string
    }

    type VariantData = {
      id: string
      label: string
      summary: string
    }

    type PickerData = {
      defaultSelection: {
        themeId: string
        flavorId: string
        variantId: string
      }
      installUrl: string
      colorSystemUrl: string
      themes: ThemeData[]
      flavors: FlavorData[]
      variants: VariantData[]
      copy: {
        installCta: string
        previewCta: string
      }
    }

    const catalogEl = root.querySelector('[data-hero-catalog]')
    if (!catalogEl?.textContent) return

    const data = JSON.parse(catalogEl.textContent) as PickerData
    let selectedThemeId = (root.getAttribute('data-default-theme') || data.defaultSelection.themeId || '').trim()
    let selectedFlavorId = data.defaultSelection.flavorId || data.flavors[0]?.id || ''
    let selectedVariantId = data.defaultSelection.variantId || data.variants[0]?.id || ''

    const flavorButtons = Array.from(root.querySelectorAll('[data-hero-flavor]'))
    const variantButtons = Array.from(root.querySelectorAll('[data-hero-variant]'))
    const titleEl = root.querySelector('[data-hero-title]')
    const bodyEl = root.querySelector('[data-hero-body]')
    const currentEl = root.querySelector('[data-hero-current]')
    const primaryEl = root.querySelector('[data-hero-primary]')

    const getTheme = (themeId: string) => data.themes.find((theme) => theme.id === themeId) || data.themes[0]
    const getFlavor = (flavorId: string) => data.flavors.find((flavor) => flavor.id === flavorId) || data.flavors[0]
    const getVariant = (variantId: string) => data.variants.find((variant) => variant.id === variantId) || data.variants[0]
    const getThemeByFlavorVariant = (flavorId: string, variantId: string) => (
      data.themes.find((theme) => theme.schemeId === flavorId && theme.variantId === variantId)
      || data.themes.find((theme) => theme.schemeId === flavorId)
      || data.themes[0]
    )

    const applyPaletteVars = (el: Element | null, theme: ThemeData) => {
      if (!(el instanceof HTMLElement)) return
      const swatches = Object.fromEntries(theme.swatches.map((swatch) => [swatch.id, swatch.color]))
      el.style.setProperty('--pick-surface', theme.surface)
      el.style.setProperty('--pick-ink', theme.foreground)
      el.style.setProperty('--pick-accent', theme.accent)
      el.style.setProperty('--pick-keyword', swatches.keyword || theme.accent)
      el.style.setProperty('--pick-function', swatches.function || theme.foreground)
      el.style.setProperty('--pick-property', swatches.property || theme.foreground)
      el.style.setProperty('--pick-type', swatches.type || theme.foreground)
    }

    const sync = () => {
      const theme = getThemeByFlavorVariant(selectedFlavorId, selectedVariantId)
      selectedThemeId = theme.id
      selectedFlavorId = theme.schemeId
      selectedVariantId = theme.variantId

      flavorButtons.forEach((button) => {
        const flavorId = button.getAttribute('data-flavor-id') || ''
        const flavor = getFlavor(flavorId)
        const representativeTheme = getTheme(flavor.representativeThemeId)
        const isActive = flavorId === selectedFlavorId
        button.classList.toggle('is-active', isActive)
        button.setAttribute('aria-pressed', isActive ? 'true' : 'false')
        applyPaletteVars(button, representativeTheme)
      })

      variantButtons.forEach((button) => {
        const variantId = button.getAttribute('data-variant-id') || ''
        const variantTheme = getThemeByFlavorVariant(selectedFlavorId, variantId)
        const isActive = variantId === selectedVariantId
        button.classList.toggle('is-active', isActive)
        button.setAttribute('aria-pressed', isActive ? 'true' : 'false')
        applyPaletteVars(button, variantTheme)
      })
      applyPaletteVars(currentEl, theme)

      if (titleEl instanceof HTMLElement) titleEl.textContent = theme.label
      if (bodyEl instanceof HTMLElement) bodyEl.textContent = theme.summary
      if (primaryEl instanceof HTMLAnchorElement) {
        primaryEl.href = theme.isPublished ? data.installUrl : data.colorSystemUrl
        primaryEl.textContent = theme.isPublished ? data.copy.installCta : data.copy.previewCta
      }

      window.dispatchEvent(
        new CustomEvent('theme-fit-preview', {
          detail: {
            themeId: selectedThemeId,
          },
        }),
      )
    }

    flavorButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const flavorId = button.getAttribute('data-flavor-id')
        if (!flavorId) return
        selectedFlavorId = flavorId
        sync()
      })
    })

    variantButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const variantId = button.getAttribute('data-variant-id')
        if (!variantId) return
        selectedVariantId = variantId
        sync()
      })
    })

    sync()
  })
</script>
