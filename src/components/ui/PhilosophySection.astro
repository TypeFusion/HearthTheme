---
import { t, type Lang } from '../../i18n/utils'
import { tokens } from '../../data/tokens'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const d = tokens.dark
const s = tokens.darkSoft
const l = tokens.light
const ls = tokens.lightSoft

const bgSwatches = [
  { id: 'dark', label: 'Hearth Dark', color: d.bg },
  { id: 'darkSoft', label: 'Dark Soft', color: s.bg },
  { id: 'light', label: 'Hearth Light', color: l.bg },
  { id: 'lightSoft', label: 'Light Soft', color: ls.bg },
]

const cards = [
  { num: '01', titleKey: 'philosophy.01.title', bodyKey: 'philosophy.01.body' },
  { num: '02', titleKey: 'philosophy.02.title', bodyKey: 'philosophy.02.body' },
  { num: '03', titleKey: 'philosophy.03.title', bodyKey: 'philosophy.03.body' },
  { num: '04', titleKey: 'philosophy.04.title', bodyKey: 'philosophy.04.body' },
]

const bodyText = (key: string) => t(lang, key)
---

<section class="hearth-section hearth-section-y" data-reveal>
  <div class="hearth-shell">
    <div class="hearth-intro">
      <p class="hearth-kicker mb-5 flex items-center gap-3">
        {t(lang, 'philosophy.label')}
        <span class="hearth-line"></span>
      </p>
    </div>

    <div class="hearth-feature-grid">
      {cards.map(({ num, titleKey, bodyKey }, index) => (
        <article
          data-reveal
          style={`--reveal-delay: ${90 + index * 70}ms;`}
          class="hearth-feature-item"
        >
          <div class="hearth-feature-index">{num}</div>
          <h3 class="hearth-feature-title">{t(lang, titleKey)}</h3>
          <p class="hearth-copy hearth-feature-body">{bodyText(bodyKey)}</p>
          {bodyKey === 'philosophy.02.body' && (
            <ul class="hearth-bg-swatch-list" aria-label={t(lang, 'philosophy.02.swatchesAria')}>
              {bgSwatches.map((swatch) => (
                <li class="hearth-bg-swatch-item">
                  <span class="hearth-bg-swatch-dot" style={`--swatch-color: ${swatch.color};`} aria-hidden="true"></span>
                  <span class="hearth-bg-swatch-name">{swatch.label}</span>
                </li>
              ))}
            </ul>
          )}
        </article>
      ))}
    </div>
  </div>
</section>
