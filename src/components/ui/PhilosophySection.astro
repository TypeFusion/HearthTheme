---
import { t, type Lang } from '../../i18n/utils'

interface Props {
  lang: Lang
}

const { lang } = Astro.props

const cards = [
  { num: '01', titleKey: 'philosophy.01.title', bodyKey: 'philosophy.01.body' },
  { num: '02', titleKey: 'philosophy.02.title', bodyKey: 'philosophy.02.body' },
  { num: '03', titleKey: 'philosophy.03.title', bodyKey: 'philosophy.03.body' },
  { num: '04', titleKey: 'philosophy.04.title', bodyKey: 'philosophy.04.body' },
]
---

<section class="hearth-section py-[10vh]" data-reveal>
  <p class="hearth-kicker text-[#a46d36] mb-10 sm:mb-12 flex items-center gap-3">
    {t(lang, 'philosophy.label')}
    <span class="block w-16 h-px bg-[#3a3020]"></span>
  </p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-px hearth-panel max-w-[940px]">
    {cards.map(({ num, titleKey, bodyKey }) => (
      <div class="hearth-card bg-[#16120e]/92 hover:bg-[#201913]/96 p-7 sm:p-10">
        <div class="font-serif text-4xl sm:text-5xl font-light text-[#4a3a26] leading-none mb-4">{num}</div>
        <h3 class="font-serif text-[1.26rem] sm:text-[1.42rem] tracking-[0.01em] text-[#eadfcb] mb-3">{t(lang, titleKey)}</h3>
        <p class="hearth-copy text-[14px] text-[#a29176]">{t(lang, bodyKey)}</p>
      </div>
    ))}
  </div>
</section>
