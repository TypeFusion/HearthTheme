					<li class="flex items-center justify-between border-b border-[#1f1a13] pb-2">
						<span class="text-[#a39278]">light fg/bg</span>
						<span class="font-mono text-[#d6cab4]">{snapshot.lightFgBg}</span>
					</li>
					<li class="flex items-center justify-between border-b border-[#1f1a13] pb-2">
						<span class="text-[#a39278]">dark comment</span>
						<span class="font-mono text-[#d6cab4]">{snapshot.darkComment}</span>
					</li>
					<li class="flex items-center justify-between border-b border-[#1f1a13] pb-2">
						<span class="text-[#a39278]">light comment</span>
						<span class="font-mono text-[#d6cab4]">{snapshot.lightComment}</span>
					</li>
					<li class="flex items-center justify-between border-b border-[#1f1a13] pb-2">
						<span class="text-[#a39278]">dark operator</span>
						<span class="font-mono text-[#d6cab4]">{snapshot.darkOperator}</span>
					</li>
					<li class="flex items-center justify-between">
						<span class="text-[#a39278]">light operator</span>
						<span class="font-mono text-[#d6cab4]">{snapshot.lightOperator}</span>
					</li>
				</ul>
			</div>
		</section>

		<section class="hearth-panel hearth-card bg-[#120f0b] p-5 sm:p-7">
			<h2 class="font-serif text-2xl text-[#d6cab4] mb-5">{c.protocolTitle}</h2>
			<ol class="list-decimal pl-5 space-y-2 text-[#a39278] text-sm leading-relaxed">
				{c.protocol.map((line) => <li>{line}</li>)}
			</ol>
		</section>

		<section class="hearth-panel hearth-card bg-[#120f0b] p-5 sm:p-7">
			<h2 class="font-serif text-2xl text-[#d6cab4] mb-2">{c.changelogTitle}</h2>
			<p class="hearth-copy text-[#91826b] text-sm mb-6">{c.changelogSubtitle}</p>
			{
				changelogRows.length === 0 ? (
					<p class="hearth-copy text-[#a39278] text-sm">{c.noReleaseNotes}</p>
				) : (
					<div class="grid gap-4">
						{
							changelogRows.map((entry) => (
								<article class="hearth-panel hearth-card bg-[#17130f] p-5">
									<div class="flex items-center justify-between gap-4 mb-3">
										<span class="font-mono text-[12px] text-[#d6cab4]">{entry.version}</span>
										{entry.date ? (
											<span class="font-mono text-[11px] text-[#91826b]">{entry.date}</span>
										) : null}
									</div>
									<h3 class="font-serif text-xl text-[#d6cab4] mb-2">{c.releasePrefix} {entry.version}</h3>
									<p class="hearth-copy text-[#a39278] text-sm leading-relaxed mb-3">{entry.summary}</p>
									{
										entry.changes.length > 0 ? (
											<ul class="space-y-1.5 text-[#b9ab93] text-sm leading-relaxed hearth-copy">
												{entry.changes.map((line) => <li>• {line}</li>)}
											</ul>
										) : null
									}
								</article>
							))
						}
					</div>
				)
			}
		</section>
	</div>
</section>
