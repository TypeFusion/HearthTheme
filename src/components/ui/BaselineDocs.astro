					</tbody>
				</table>
			</div>
		</section>

		<section class="grid lg:grid-cols-2 gap-8">
			<div class="hearth-panel hearth-card bg-[#120f0b] p-5 sm:p-7">
				<h2 class="font-serif text-2xl text-[#d6cab4] mb-5">{c.budgetTitle}</h2>
				<table class="w-full text-sm">
					<thead>
						<tr class="border-b border-[#2c261b]">
							<th class="text-left text-[#a39278] hearth-meta py-3 pr-4">{c.budgetMetric}</th>
							<th class="text-left text-[#a39278] hearth-meta py-3">{c.budgetTarget}</th>
						</tr>
					</thead>
					<tbody>
						{
							budgetRows.map((row) => (
								<tr class="border-b border-[#1f1a13]">
									<td class="py-3 pr-4 text-[#c1b59f]">{row.metric}</td>
									<td class="py-3 text-[#d6cab4] font-mono text-[12px]">{row.target}</td>
								</tr>
							))
						}
					</tbody>
				</table>
			</div>

			<div class="hearth-panel hearth-card bg-[#120f0b] p-5 sm:p-7">
				<h2 class="font-serif text-2xl text-[#d6cab4] mb-5">{c.snapshotTitle}</h2>
				<ul class="space-y-3 text-sm">
