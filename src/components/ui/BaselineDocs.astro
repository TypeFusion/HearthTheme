					<thead>
						<tr class="border-b border-[#2c261b]">
							<th class="text-left text-[#a39278] hearth-meta py-3 pr-4">{c.role}</th>
							<th class="text-left text-[#a39278] hearth-meta py-3 pr-4">{c.dark}</th>
							<th class="text-left text-[#a39278] hearth-meta py-3 pr-4">{c.light}</th>
							<th class="text-left text-[#a39278] hearth-meta py-3">{c.narrative}</th>
						</tr>
					</thead>
					<tbody>
						{
							semanticRows.map((row) => (
								<tr class="border-b border-[#1f1a13]">
									<td class="py-3 pr-4 text-[#d6cab4] font-mono text-[12px]">{row.role}</td>
									<td class="py-3 pr-4">
										<span class="inline-flex items-center gap-2 font-mono text-[12px] text-[#c1b59f]">
											<span class="inline-block w-3.5 h-3.5 rounded-sm border border-[#2c261b]" style={`background: ${row.dark}`}></span>
											{row.dark}
										</span>
									</td>
									<td class="py-3 pr-4">
										<span class="inline-flex items-center gap-2 font-mono text-[12px] text-[#c1b59f]">
											<span class="inline-block w-3.5 h-3.5 rounded-sm border border-[#2c261b]" style={`background: ${row.light}`}></span>
											{row.light}
										</span>
									</td>
									<td class="py-3 text-[#a39278]">{row.note}</td>
								</tr>
							))
