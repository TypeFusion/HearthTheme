---
import { t, type Lang } from "../../i18n/utils";
import { tokens } from "../../data/tokens";

interface Props {
    lang: Lang;
}

const { lang } = Astro.props;
const d = tokens.dark;
const l = tokens.light;

const colorRows = [
    {
        swatch: d.bg,
        name: "bg · dark",
        hex: d.bg,
        role: {
            en: "Dark canvas — soot blackboard beside the hearth",
            zh: "深色画布 — 壁炉旁的炭黑黑板底",
            ja: "ダークキャンバス — 暖炉脇の煤けた黒板面",
        },
        contrast: "—",
        level: "",
    },
    {
        swatch: d.fg,
        name: "fg · dark",
        hex: d.fg,
        role: {
            en: "Dark foreground — chalky parchment white for long focus",
            zh: "深色正文 — 粉笔羊皮纸白，适合长时专注",
            ja: "ダーク前景 — 長時間読解向けのチョーク系羊皮紙ホワイト",
        },
        contrast: "11.4:1",
        level: "aaa",
    },
    {
        swatch: d.keyword,
        name: "keyword",
        hex: d.keyword,
        role: {
            en: "Keywords — ember red for control flow anchors",
            zh: "关键字 — 余烬红，用于控制流锚点",
            ja: "キーワード — 制御フローを示す余燼レッド",
        },
        contrast: "6.2:1",
        level: "aa",
    },
    {
        swatch: d.fn,
        name: "function",
        hex: d.fn,
        role: {
            en: "Functions — brass amber for callable targets",
            zh: "函数名 — 黄铜琥珀色，用于可调用目标",
            ja: "関数名 — 呼び出し対象を示すブラスアンバー",
        },
        contrast: "7.5:1",
        level: "aaa",
    },
    {
        swatch: d.string,
        name: "string",
        hex: d.string,
        role: {
            en: "Strings — moss green with warm base",
            zh: "字符串 — 苔绿，保留暖底",
            ja: "文字列 — 暖かさを残したモスグリーン",
        },
        contrast: "5.6:1",
        level: "aa",
    },
    {
        swatch: d.type,
        name: "type",
        hex: d.type,
        role: {
            en: "Types — mineral teal + italic for structural symbols",
            zh: "类型 — 矿物青 + 斜体，用于结构符号",
            ja: "型 — 構造記号のためのミネラルティール + イタリック",
        },
        contrast: "6.0:1",
        level: "aa",
    },
    {
        swatch: d.number,
        name: "number",
        hex: d.number,
        role: {
            en: "Numbers — terracotta red for constants",
            zh: "数字 — 赤陶色，用于常量",
            ja: "数値 — 定数を示すテラコッタレッド",
        },
        contrast: "5.3:1",
        level: "aa",
    },
    {
        swatch: d.comment,
        name: "comment",
        hex: d.comment,
        role: {
            en: "Comments — intentionally dim, eye skips naturally",
            zh: "注释 — 故意低亮度，视线自然略过",
            ja: "コメント — 意図的に暗く",
        },
        contrast: "3.0:1",
        level: "dec",
    },
    {
        swatch: l.bg,
        name: "bg · light",
        hex: l.bg,
        role: {
            en: "Light background — parchment off-white to reduce glare",
            zh: "浅色背景 — 羊皮纸米白，降低炫光",
            ja: "ライト背景 — 眩しさを抑える羊皮紙オフホワイト",
        },
        contrast: "—",
        level: "",
    },
    {
        swatch: l.fg,
        name: "fg · light",
        hex: l.fg,
        role: {
            en: "Light foreground — deep walnut brown for long-form reading",
            zh: "浅色正文 — 深胡桃棕，适合长时阅读",
            ja: "ライト前景 — 長文読解向けの深いウォルナットブラウン",
        },
        contrast: "11.6:1",
        level: "aaa",
    },
];

const levelClass: Record<string, string> = {
    aaa: "border-[#90aa78] text-[#90aa78]",
    aa: "border-[#ddb86a] text-[#ddb86a]",
    dec: "border-[#3a3020] text-[#4a4030]",
    "": "border-[#3a3020] text-[#4a4030]",
};
---

<section
    class="px-[8vw] py-[10vh] reveal"
    style={`background: ${d.sidebar}; border-top: 1px solid ${d.border}; border-bottom: 1px solid ${d.border};`}
>
    <p
        class="font-mono text-[10px] tracking-[0.18em] uppercase mb-12 flex items-center gap-3"
        style={`color: ${d.operator}`}
    >
        {t(lang, "colors.label")}
        <span class="block w-16 h-px" style={`background: ${d.border}`}></span>
    </p>

    <div class="flex flex-col max-w-[860px]">
        {
            colorRows.map(({ swatch, name, hex, role, contrast, level }) => (
                <div
                    class="flex items-stretch hover:opacity-90 transition-opacity"
                    style={`border-bottom: 1px solid ${d.border}`}
                >
                    <div
                        class="w-16 flex-shrink-0"
                        style={`background: ${swatch}`}
                    />
                    <div
                        class="flex items-center gap-6 px-5 py-3.5 flex-1 min-w-0"
                        style={`background: ${d.bg}`}
                    >
                        <span
                            class="font-mono text-[11px] w-24 flex-shrink-0"
                            style={`color: ${d.fg}`}
                        >
                            {name}
                        </span>
                        <span
                            class="font-mono text-[11px] w-20 flex-shrink-0"
                            style={`color: ${d.comment}`}
                        >
                            {hex}
                        </span>
                        <span
                            class="text-[12px] flex-1 min-w-0"
                            style={`color: ${d.variable}`}
                        >
                            {role[lang as keyof typeof role]}
                        </span>
                        <span
                            class={`font-mono text-[10px] px-2.5 py-1 rounded-full border flex-shrink-0 ${levelClass[level]}`}
                        >
                            {contrast}
                            {level === "aaa"
                                ? " AAA"
                                : level === "aa"
                                  ? " AA"
                                  : level === "dec"
                                    ? " dec"
                                    : ""}
                        </span>
                    </div>
                </div>
            ))
        }
    </div>
</section>

<style>
    .reveal {
        opacity: 0;
        transform: translateY(20px);
        transition:
            opacity 0.7s,
            transform 0.7s;
    }
    .reveal.visible {
        opacity: 1;
        transform: translateY(0);
    }
</style>

<script>
    const observer = new IntersectionObserver(
        (entries) => {
            entries.forEach((e) => {
                if (e.isIntersecting) e.target.classList.add("visible");
            });
        },
        { threshold: 0.1 },
    );
    document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
</script>
