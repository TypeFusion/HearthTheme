---
import { t, type Lang } from "../../i18n/utils";
import { tokens } from "../../data/tokens";
import { getColorRows } from "../../data/colorSystemRows";

interface Props {
    lang: Lang;
}

const { lang } = Astro.props;
const docsUrl = lang === "en" ? "/docs" : `/${lang}/docs`;
const reportUrl = "https://github.com/hearth-code/HearthTheme/blob/main/docs/color-language-report.md";
const sourceUrl = "https://github.com/hearth-code/HearthTheme/tree/main/color-system";

function hexToRgb(hex: string) {
    const raw = hex.slice(1);
    return [
        Number.parseInt(raw.slice(0, 2), 16),
        Number.parseInt(raw.slice(2, 4), 16),
        Number.parseInt(raw.slice(4, 6), 16),
    ];
}

function toLinear(channel: number) {
    const c = channel / 255;
    return c <= 0.03928 ? c / 12.92 : ((c + 0.055) / 1.055) ** 2.4;
}

function contrastRatio(a: string, b: string) {
    const [ar, ag, ab] = hexToRgb(a).map(toLinear);
    const [br, bg, bb] = hexToRgb(b).map(toLinear);
    const la = 0.2126 * ar + 0.7152 * ag + 0.0722 * ab;
    const lb = 0.2126 * br + 0.7152 * bg + 0.0722 * bb;
    const hi = Math.max(la, lb);
    const lo = Math.min(la, lb);
    return (hi + 0.05) / (lo + 0.05);
}

const colorRows = getColorRows().map((row) => {
    if (!row.bgRef) {
        return {
            ...row,
            contrast: "—",
            level: "",
        };
    }

    const ratio = contrastRatio(row.swatch, row.bgRef);
    const level = ratio >= 7 ? "aaa" : ratio >= 4.5 ? "aa" : "dec";
    return {
        ...row,
        contrast: `${ratio.toFixed(1)}:1`,
        level,
    };
});

const levelClass: Record<string, string> = {
    aaa: "hearth-badge-aaa",
    aa: "hearth-badge-aa",
    dec: "hearth-badge-dec",
    "": "hearth-badge-dec",
};
---

<section class="hearth-section hearth-section-y" data-reveal>
    <div class="hearth-shell">
        <div class="hearth-intro">
            <p class="hearth-kicker mb-5 flex items-center gap-3">
                {t(lang, "colors.label")}
                <span class="hearth-line"></span>
            </p>
        </div>

        <div class="max-w-[1020px]">
            {
                colorRows.map(({ swatch, name, hex, roleKey, contrast, level, contextVariant, bgRef }) => {
                    const rowTokens = tokens[contextVariant];
                    const rowBg = bgRef ?? rowTokens.bg;

                    return (
                        <div
                            class="flex flex-col sm:flex-row items-stretch transition-opacity duration-300 hover:opacity-94"
                            style="border-bottom: 1px solid var(--hearth-colorsystem-row-border)"
                        >
                            <div
                                class="w-full h-3 sm:h-auto sm:w-[4.6rem] flex-shrink-0"
                                style={`background: ${swatch}`}
                            />
                            <div
                                class="flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-7 px-4 sm:px-6 py-4 sm:py-[1.05rem] flex-1 min-w-0"
                                style={`background: ${rowBg}`}
                            >
                                <span
                                    class="font-mono text-[12.5px] sm:w-28 flex-shrink-0"
                                    style={`color: ${rowTokens.fg}`}
                                >
                                    {name}
                                </span>
                                <span
                                    class="font-mono text-[12px] sm:w-24 flex-shrink-0"
                                    style={`color: ${rowTokens.comment}`}
                                >
                                    {hex}
                                </span>
                                <span
                                    class="hearth-copy text-[14px] sm:text-[15px] flex-1 min-w-0 leading-[1.7]"
                                    style={`color: ${rowTokens.variable}`}
                                >
                                    {t(lang, roleKey)}
                                </span>
                                <span
                                    class={`font-mono text-[10px] px-2.5 py-1 rounded-[4px] border flex-shrink-0 self-start sm:self-auto ${levelClass[level]}`}
                                >
                                    {contrast}
                                    {level === "aaa"
                                        ? " AAA"
                                        : level === "aa"
                                          ? " AA"
                                          : level === "dec"
                                            ? " dec"
                                            : ""}
                                </span>
                            </div>
                        </div>
                    );
                })
            }

            <article class="hearth-proof-metric-card rounded-xl px-4 sm:px-5 py-4 sm:py-5 mt-5">
                <h3 class="hearth-proof-variant-title font-ui text-[1rem] font-semibold mb-2">
                    {t(lang, "colors.proof.title")}
                </h3>
                <p class="hearth-copy hearth-meta-muted text-[0.95rem] leading-[1.68] mb-3">
                    {t(lang, "colors.proof.body")}
                </p>
                <div class="flex flex-wrap gap-2.5 text-[0.8rem] font-ui tracking-[0.01em]">
                    <a
                        href={docsUrl}
                        class="hearth-btn-secondary inline-flex items-center gap-1.5 rounded-full border px-3.5 py-1.5 font-semibold"
                    >
                        <span>{t(lang, "colors.proof.cta.docs")}</span>
                        <span aria-hidden="true">→</span>
                    </a>
                    <a
                        href={reportUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="hearth-btn-tertiary inline-flex items-center gap-1.5 rounded-full border px-3.5 py-1.5 font-semibold"
                    >
                        <span>{t(lang, "colors.proof.cta.report")}</span>
                        <span aria-hidden="true">↗</span>
                    </a>
                    <a
                        href={sourceUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="hearth-btn-tertiary inline-flex items-center gap-1.5 rounded-full border px-3.5 py-1.5 font-semibold"
                    >
                        <span>{t(lang, "colors.proof.cta.source")}</span>
                        <span aria-hidden="true">↗</span>
                    </a>
                </div>
            </article>
        </div>
    </div>
</section>
