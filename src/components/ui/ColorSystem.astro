---
import { t, type Lang } from "../../i18n/utils";
import { tokens } from "../../data/tokens";

interface Props {
    lang: Lang;
}

const { lang } = Astro.props;
const d = tokens.dark;
const l = tokens.light;

const colorRows = [
    {
        swatch: d.bg,
        name: "bg · dark",
        hex: d.bg,
        role: {
            en: "Editor background — warm deep brown, not pure black",
            zh: "编辑器主背景 — 深暖棕，非纯黑",
            ja: "エディタ背景 — 暖かみのある深茶色",
        },
        contrast: "—",
        level: "",
    },
    {
        swatch: d.fg,
        name: "fg · dark",
        hex: d.fg,
        role: {
            en: "Foreground — warm off-white, not pure white",
            zh: "正文颜色 — 暖米色，非纯白",
            ja: "前景色 — 暖かみのあるオフホワイト",
        },
        contrast: "7.4:1",
        level: "aaa",
    },
    {
        swatch: d.keyword,
        name: "keyword",
        hex: d.keyword,
        role: {
            en: "Keywords — muted clay orange",
            zh: "关键字 — 低饱和陶土橙",
            ja: "キーワード — くすんだ粘土色",
        },
        contrast: "5.8:1",
        level: "aa",
    },
    {
        swatch: d.fn,
        name: "function",
        hex: d.fn,
        role: {
            en: "Functions — muted amber gold",
            zh: "函数名 — 低饱和琥珀金",
            ja: "関数名 — くすんだ琥珀色",
        },
        contrast: "7.2:1",
        level: "aaa",
    },
    {
        swatch: d.string,
        name: "string",
        hex: d.string,
        role: {
            en: "Strings — muted moss green, warm-toned",
            zh: "字符串 — 低饱和苔绿，融入暖调",
            ja: "文字列 — くすんだ苔色",
        },
        contrast: "5.2:1",
        level: "aa",
    },
    {
        swatch: d.type,
        name: "type",
        hex: d.type,
        role: {
            en: "Types — warm tan + italic",
            zh: "类型 — 暖棕褐 + 斜体",
            ja: "型 — 暖かみのある茶色 + イタリック",
        },
        contrast: "5.5:1",
        level: "aa",
    },
    {
        swatch: d.number,
        name: "number",
        hex: d.number,
        role: {
            en: "Numbers — muted terracotta",
            zh: "数字 — 低饱和赤土色",
            ja: "数値 — くすんだテラコッタ",
        },
        contrast: "5.0:1",
        level: "aa",
    },
    {
        swatch: d.comment,
        name: "comment",
        hex: d.comment,
        role: {
            en: "Comments — intentionally dim, eye skips naturally",
            zh: "注释 — 故意低亮度，视线自然略过",
            ja: "コメント — 意図的に暗く",
        },
        contrast: "3.0:1",
        level: "dec",
    },
    {
        swatch: l.bg,
        name: "bg · light",
        hex: l.bg,
        role: {
            en: "Light background — warm off-white, low blue light",
            zh: "浅色背景 — 暖调米白，低蓝光",
            ja: "ライト背景 — 暖かみのあるオフホワイト",
        },
        contrast: "—",
        level: "",
    },
    {
        swatch: l.fg,
        name: "fg · light",
        hex: l.fg,
        role: {
            en: "Light foreground — deep warm brown, 12:1 contrast",
            zh: "浅色正文 — 深暖棕，对比度 12:1",
            ja: "ライト前景 — 深い暖かみのある茶色",
        },
        contrast: "12:1",
        level: "aaa",
    },
];

const levelClass: Record<string, string> = {
    aaa: "border-[#90aa78] text-[#90aa78]",
    aa: "border-[#ddb86a] text-[#ddb86a]",
    dec: "border-[#3a3020] text-[#4a4030]",
    "": "border-[#3a3020] text-[#4a4030]",
};
---

<section
    class="px-[8vw] py-[10vh] reveal"
    style={`background: ${d.sidebar}; border-top: 1px solid ${d.border}; border-bottom: 1px solid ${d.border};`}
>
    <p
        class="font-mono text-[10px] tracking-[0.18em] uppercase mb-12 flex items-center gap-3"
        style={`color: ${d.operator}`}
    >
        {t(lang, "colors.label")}
        <span class="block w-16 h-px" style={`background: ${d.border}`}></span>
    </p>

    <div class="flex flex-col max-w-[860px]">
        {
            colorRows.map(({ swatch, name, hex, role, contrast, level }) => (
                <div
                    class="flex items-stretch hover:opacity-90 transition-opacity"
                    style={`border-bottom: 1px solid ${d.border}`}
                >
                    <div
                        class="w-16 flex-shrink-0"
                        style={`background: ${swatch}`}
                    />
                    <div
                        class="flex items-center gap-6 px-5 py-3.5 flex-1 min-w-0"
                        style={`background: ${d.bg}`}
                    >
                        <span
                            class="font-mono text-[11px] w-24 flex-shrink-0"
                            style={`color: ${d.fg}`}
                        >
                            {name}
                        </span>
                        <span
                            class="font-mono text-[11px] w-20 flex-shrink-0"
                            style={`color: ${d.comment}`}
                        >
                            {hex}
                        </span>
                        <span
                            class="text-[12px] flex-1 min-w-0"
                            style={`color: ${d.variable}`}
                        >
                            {role[lang as keyof typeof role]}
                        </span>
                        <span
                            class={`font-mono text-[10px] px-2.5 py-1 rounded-full border flex-shrink-0 ${levelClass[level]}`}
                        >
                            {contrast}
                            {level === "aaa"
                                ? " AAA"
                                : level === "aa"
                                  ? " AA"
                                  : level === "dec"
                                    ? " dec"
                                    : ""}
                        </span>
                    </div>
                </div>
            ))
        }
    </div>
</section>

<style>
    .reveal {
        opacity: 0;
        transform: translateY(20px);
        transition:
            opacity 0.7s,
            transform 0.7s;
    }
    .reveal.visible {
        opacity: 1;
        transform: translateY(0);
    }
</style>

<script>
    const observer = new IntersectionObserver(
        (entries) => {
            entries.forEach((e) => {
                if (e.isIntersecting) e.target.classList.add("visible");
            });
        },
        { threshold: 0.1 },
    );
    document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
</script>
