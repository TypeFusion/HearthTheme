---
import "../styles/global.css";
import { t, languages, type Lang } from "../i18n/utils";

interface Props {
	title?: string;
	description?: string;
	lang?: Lang;
}

const { lang = "en", title, description } = Astro.props;
const url = Astro.url;

const pageTitle = title ? `${title} — Hearth` : "Hearth — VSCode Color Theme";

const pageDescription = description ?? t(lang, "hero.subtitle");

const home = lang === "en" ? "/" : `/${lang}`;
const docs = lang === "en" ? "/docs" : `/${lang}/docs`;
const marketplaceUrl = "https://marketplace.visualstudio.com/items?itemName=hearth-code.hearth-theme";
const isDocsPage = /\/docs\/?$/.test(url.pathname);
const isHomePage = !isDocsPage;
const installFontClass =
	lang === "en"
		? "font-mono tracking-[0.05em] sm:tracking-[0.06em]"
		: "font-ui tracking-[0.02em]";
const langLinkBase = "hearth-meta transition-colors";
const langLinkActive = `${langLinkBase} text-[#d7a162]`;
const langLinkIdle = `${langLinkBase} text-[#5f503d] hover:text-[#9e8a6a]`;
const footerMetaClass = `${lang === "en" ? "font-mono" : "font-ui"} hearth-meta text-[#504838]`;
const siteBase = Astro.site ?? new URL(url.origin);
const langHref = (target: Lang) =>
	isDocsPage
		? target === "en"
			? "/docs"
			: `/${target}/docs`
		: target === "en"
			? "/"
			: `/${target}`;
const absoluteLangHref = (target: Lang) => new URL(langHref(target), siteBase).href;
const canonicalUrl = new URL(url.pathname + url.search, siteBase).href;
const defaultUrl = new URL(isDocsPage ? "/docs" : "/", siteBase).href;
const ogImage = new URL("/og-hearth.png", siteBase).href;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={pageDescription} />
		<meta name="author" content="Hearth" />
		<meta name="theme-color" content="#1e1a12" />

		<!-- Open Graph -->
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={pageDescription} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content="Hearth" />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:alt" content="Hearth Theme preview" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={pageDescription} />
		<meta name="twitter:image" content={ogImage} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
		<link
			href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600&display=swap"
			rel="stylesheet"
		/>

		<!-- hreflang for i18n SEO -->
		{
			Object.keys(languages).map((l) => (
				<link
					rel="alternate"
					hreflang={l}
					href={absoluteLangHref(l as Lang)}
				/>
			))
		}
		<link rel="alternate" hreflang="x-default" href={defaultUrl} />
		<link rel="canonical" href={canonicalUrl} />

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" sizes="512x512" href="/icon-512.png" />
		<link rel="apple-touch-icon" href="/icon-512.png" />
		<title>{pageTitle}</title>
	</head>
	<body class="app-shell">
		<!-- Nav -->
		<nav
			class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-4 sm:px-6 lg:px-8 py-3 sm:py-4 border-b border-[#3a3020]/60 backdrop-blur-sm bg-[#15120f]/82"
		>
			<a
				href={home}
				class="font-serif text-[1.12rem] sm:text-[1.35rem] italic text-[#e8dcc8] tracking-[0.02em] flex items-center gap-2 sm:gap-2.5"
			>
				<img
					src="/favicon.svg"
					alt="Hearth"
					class="h-6 w-6 rounded-sm border border-[#3a3020]/70 bg-[#161411] p-0.5 shadow-[0_4px_16px_rgba(0,0,0,0.28)]"
				/>
				Hearth
			</a>

			<div class="flex items-center gap-2.5 sm:gap-5 md:gap-8">
				<a
					href={home}
					class={`hearth-nav-link font-ui text-[11px] sm:text-sm ${isHomePage ? "is-active" : ""}`}
				>
					{t(lang, "nav.home")}
				</a>
				<a
					href={docs}
					class={`hearth-nav-link font-ui text-[11px] sm:text-sm ${isDocsPage ? "is-active" : ""}`}
				>
					{t(lang, "nav.docs")}
				</a>
				<a
					href={marketplaceUrl}
					target="_blank"
					class={`hearth-cta ${installFontClass} text-[10px] sm:text-[11px] px-2.5 sm:px-4 py-1.5 rounded-sm`}
				>
					{t(lang, "nav.install")}
				</a>

				<div
					class="flex items-center gap-1.5 sm:gap-2 border-l border-[#3a3020] pl-2.5 sm:pl-5"
				>
					<a
						href={langHref("en")}
						class={lang === "en" ? langLinkActive : langLinkIdle}
						>en</a
					>
					<a
						href={langHref("zh")}
						class={lang === "zh" ? langLinkActive : langLinkIdle}
						>zh</a
					>
					<a
						href={langHref("ja")}
						class={lang === "ja" ? langLinkActive : langLinkIdle}
						>ja</a
					>
				</div>
			</div>
		</nav>

		<!-- Page content -->
		<main class="pt-[66px] sm:pt-[68px]">
			<slot />
		</main>

		<!-- Footer -->
		<footer
			class="border-t border-[#3a3020] px-4 sm:px-6 lg:px-8 py-8 flex flex-col sm:flex-row items-start sm:items-center gap-2 sm:gap-0 justify-between"
		>
			<span class="font-serif italic text-[#8a7e6a]">Hearth</span>
			<span class={footerMetaClass}>
				Hearth.dev &nbsp;·&nbsp; {t(lang, "footer.tagline")}
			</span>
		</footer>
		<script is:inline>
			(() => {
				if (window.__hearthRevealInit) return;
				window.__hearthRevealInit = true;
				const targets = document.querySelectorAll("[data-reveal]");
				if (!targets.length) return;

				const reveal = (el) => el.classList.add("is-visible");
				if (!("IntersectionObserver" in window)) {
					targets.forEach((el) => reveal(el));
					return;
				}

				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (!entry.isIntersecting) return;
							reveal(entry.target);
							observer.unobserve(entry.target);
						});
					},
					{ threshold: 0.14, rootMargin: "0px 0px -8% 0px" },
				);
				targets.forEach((el) => observer.observe(el));
			})();
		</script>
	</body>
</html>
