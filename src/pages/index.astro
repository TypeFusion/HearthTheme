---
import Layout from '../layouts/Layout.astro'
import HeroSection from '../components/ui/HeroSection.astro'
import ProofSection from '../components/ui/ProofSection.astro'
import ImplementationSection from '../components/ui/ImplementationSection.astro'
import PhilosophySection from '../components/ui/PhilosophySection.astro'
import ColorSystem from '../components/ui/ColorSystem.astro'
import FinalCtaSection from '../components/ui/FinalCtaSection.astro'

const lang = 'en'
---

<Layout lang={lang}>
  <HeroSection lang={lang} />
  <ProofSection lang={lang} />
  <ImplementationSection lang={lang} />
  <PhilosophySection lang={lang} />
  <ColorSystem lang={lang} />
  <FinalCtaSection lang={lang} />
</Layout>
