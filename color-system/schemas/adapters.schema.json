{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hearthcode.dev/schemas/color-system/adapters.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "roles",
    "description",
    "surfaces",
    "interactions",
    "feedbacks",
    "interfaces",
    "guidances",
    "terminals"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "description": {
      "$ref": "https://hearthcode.dev/schemas/color-system/common.schema.json#/definitions/nonEmptyString"
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "scopes",
          "semanticKeys",
          "vscodeSemantic",
          "obsidianVar",
          "webToken",
          "includeInReport"
        ],
        "properties": {
          "id": {
            "$ref": "https://hearthcode.dev/schemas/color-system/common.schema.json#/definitions/nonEmptyString"
          },
          "scopes": {
            "type": "array",
            "items": {
              "$ref": "https://hearthcode.dev/schemas/color-system/common.schema.json#/definitions/nonEmptyString"
            }
          },
          "semanticKeys": {
            "type": "array",
            "items": {
              "$ref": "https://hearthcode.dev/schemas/color-system/common.schema.json#/definitions/nonEmptyString"
            }
          },
          "vscodeSemantic": {
            "$ref": "https://hearthcode.dev/schemas/color-system/common.schema.json#/definitions/nullableString"
          },
          "obsidianVar": {
            "$ref": "https://hearthcode.dev/schemas/color-system/common.schema.json#/definitions/nullableString"
          },
          "webToken": {
            "$ref": "https://hearthcode.dev/schemas/color-system/common.schema.json#/definitions/nullableString"
          },
          "includeInReport": {
            "type": "boolean"
          },
          "requireTokenCoverage": {
            "type": "boolean"
          }
        }
      }
    },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://hearthcode.dev/schemas/color-system/common.schema.json#/definitions/platformContract"
      }
    },
    "interactions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://hearthcode.dev/schemas/color-system/common.schema.json#/definitions/platformContract"
      }
    },
    "feedbacks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://hearthcode.dev/schemas/color-system/common.schema.json#/definitions/platformContract"
      }
    },
    "interfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://hearthcode.dev/schemas/color-system/common.schema.json#/definitions/platformContract"
      }
    },
    "guidances": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://hearthcode.dev/schemas/color-system/common.schema.json#/definitions/platformContract"
      }
    },
    "terminals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://hearthcode.dev/schemas/color-system/common.schema.json#/definitions/platformContract"
      }
    }
  }
}
