{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hearthcode.dev/schemas/color-system/tuning.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "lightPolarityRoleOptimization",
    "globalSeparationTargetByVariant",
    "globalSeparationToleranceByVariant",
    "globalSeparationBoostProfileByVariant",
    "lightReadabilityCalibration",
    "lightCoolRoleSoften",
    "globalSeparationRoleProfile",
    "lightPolaritySearchProfile",
    "globalSeparationDeficitProfile",
    "lightReadabilitySearchProfile",
    "telemetryProfile",
    "pairSeparationGates",
    "interactionStateBudget",
    "darkSoftPerceptionGuard",
    "roleLaneProfile",
    "siteDocsProfile",
    "softRoleChromaBudget",
    "siteAssetMapping"
  ],
  "definitions": {
    "roleNumberMap": {
      "type": "object",
      "additionalProperties": {
        "type": "number"
      }
    },
    "roleNullableNumberMap": {
      "type": "object",
      "additionalProperties": {
        "anyOf": [
          {
            "type": "number"
          },
          {
            "type": "null"
          }
        ]
      }
    },
    "variantNumberMap": {
      "type": "object",
      "additionalProperties": {
        "type": "number"
      }
    },
    "separationTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "median",
        "p25",
        "p10"
      ],
      "properties": {
        "median": {
          "type": "number"
        },
        "p25": {
          "type": "number"
        },
        "p10": {
          "type": "number"
        }
      }
    },
    "boostProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maxNeededFactor",
        "maxBoostRounds",
        "roleBoostScale",
        "lightnessLiftScale",
        "maxChroma"
      ],
      "properties": {
        "maxNeededFactor": {
          "type": "number"
        },
        "maxBoostRounds": {
          "type": "integer",
          "minimum": 0
        },
        "roleBoostScale": {
          "type": "number"
        },
        "lightnessLiftScale": {
          "type": "number"
        },
        "maxChroma": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "calibrationProfile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bgPow": {
          "type": "number"
        },
        "fgPow": {
          "type": "number"
        },
        "wBg": {
          "type": "number"
        },
        "wFg": {
          "type": "number"
        },
        "wDrift": {
          "type": "number"
        },
        "minContrast": {
          "type": "number"
        },
        "minL": {
          "type": "number"
        },
        "maxL": {
          "type": "number"
        },
        "minScale": {
          "type": "number"
        },
        "maxScale": {
          "type": "number"
        },
        "targetL": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        },
        "wL": {
          "type": "number"
        },
        "minFgContrast": {
          "type": "number"
        }
      }
    },
    "polarityRoleRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minBgHueDistance",
        "targetBgHueDistance",
        "minAnchorDeltaE",
        "minGuardDeltaE",
        "minContrast",
        "maxDeltaEFromSeed",
        "anchorRoles",
        "guardRoles",
        "preferredRoles",
        "targetPreferredHueDistance",
        "applyOnlyWhenCompensationNeeded"
      ],
      "properties": {
        "minBgHueDistance": {
          "type": "number"
        },
        "targetBgHueDistance": {
          "type": "number"
        },
        "minAnchorDeltaE": {
          "type": "number"
        },
        "minGuardDeltaE": {
          "type": "number"
        },
        "minContrast": {
          "type": "number"
        },
        "maxDeltaEFromSeed": {
          "type": "number"
        },
        "anchorRoles": {
          "$ref": "https://hearthcode.dev/schemas/color-system/common.schema.json#/definitions/stringArray"
        },
        "guardRoles": {
          "$ref": "https://hearthcode.dev/schemas/color-system/common.schema.json#/definitions/stringArray"
        },
        "preferredRoles": {
          "$ref": "https://hearthcode.dev/schemas/color-system/common.schema.json#/definitions/stringArray"
        },
        "targetPreferredHueDistance": {
          "type": "number"
        },
        "applyOnlyWhenCompensationNeeded": {
          "type": "boolean"
        }
      }
    },
    "scoreWeights": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bg",
        "anchor",
        "contrast",
        "preferred",
        "driftPenalty"
      ],
      "properties": {
        "bg": {
          "type": "number"
        },
        "anchor": {
          "type": "number"
        },
        "contrast": {
          "type": "number"
        },
        "preferred": {
          "type": "number"
        },
        "driftPenalty": {
          "type": "number"
        }
      }
    },
    "pairGate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default"
      ],
      "properties": {
        "default": {
          "type": "number"
        },
        "byVariant": {
          "$ref": "#/definitions/variantNumberMap"
        }
      }
    },
    "interactionBudget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lineHighlightMinContrast",
        "listHoverMinContrast",
        "tabHoverMinContrast",
        "lineNumberActiveDeltaMin"
      ],
      "properties": {
        "lineHighlightMinContrast": {
          "type": "number"
        },
        "listHoverMinContrast": {
          "type": "number"
        },
        "tabHoverMinContrast": {
          "type": "number"
        },
        "lineNumberActiveDeltaMin": {
          "type": "number"
        }
      }
    },
    "nearForegroundRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minDeltaE",
        "maxDeltaE",
        "minBgContrast"
      ],
      "properties": {
        "minDeltaE": {
          "type": "number"
        },
        "maxDeltaE": {
          "type": "number"
        },
        "targetDeltaE": {
          "type": "number"
        },
        "minBgContrast": {
          "type": "number"
        }
      }
    },
    "warmHueRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hueMin",
        "hueMax",
        "minBgContrast",
        "maxDeltaEFromSeed"
      ],
      "properties": {
        "hueMin": {
          "type": "number"
        },
        "hueMax": {
          "type": "number"
        },
        "minBgContrast": {
          "type": "number"
        },
        "maxDeltaEFromSeed": {
          "type": "number"
        }
      }
    },
    "perceptionGuardFunction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hueMin",
        "hueMax",
        "maxSaturation",
        "maxLightness"
      ],
      "properties": {
        "hueMin": {
          "type": "number"
        },
        "hueMax": {
          "type": "number"
        },
        "maxSaturation": {
          "type": "number"
        },
        "maxLightness": {
          "type": "number"
        }
      }
    },
    "warmGamutGuard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "forbiddenHueMin",
        "forbiddenHueMax",
        "minSaturation",
        "roles"
      ],
      "properties": {
        "forbiddenHueMin": {
          "type": "number"
        },
        "forbiddenHueMax": {
          "type": "number"
        },
        "minSaturation": {
          "type": "number"
        },
        "roles": {
          "$ref": "https://hearthcode.dev/schemas/color-system/common.schema.json#/definitions/stringArray"
        }
      }
    },
    "variantTuningProfile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "frequencyWeight": {
          "type": "number"
        },
        "saliencyWeight": {
          "type": "number"
        },
        "baseChromaFactor": {
          "type": "number"
        },
        "minChromaFactor": {
          "type": "number"
        },
        "maxChromaFactor": {
          "type": "number"
        },
        "baseLightnessLift": {
          "type": "number"
        },
        "frequencyLightnessShift": {
          "type": "number"
        },
        "saliencyLightnessShift": {
          "type": "number"
        },
        "minLightnessLift": {
          "type": "number"
        },
        "maxLightnessLift": {
          "type": "number"
        },
        "maxChromaByRole": {
          "$ref": "#/definitions/roleNullableNumberMap"
        }
      }
    },
    "siteDocRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "key",
        "note"
      ],
      "properties": {
        "id": {
          "$ref": "https://hearthcode.dev/schemas/color-system/common.schema.json#/definitions/nonEmptyString"
        },
        "key": {
          "$ref": "https://hearthcode.dev/schemas/color-system/common.schema.json#/definitions/nonEmptyString"
        },
        "note": {
          "$ref": "https://hearthcode.dev/schemas/color-system/common.schema.json#/definitions/nonEmptyString"
        }
      }
    },
    "snapshotRatio": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "variant",
        "left",
        "right"
      ],
      "properties": {
        "label": {
          "$ref": "https://hearthcode.dev/schemas/color-system/common.schema.json#/definitions/nonEmptyString"
        },
        "variant": {
          "$ref": "https://hearthcode.dev/schemas/color-system/common.schema.json#/definitions/nonEmptyString"
        },
        "left": {
          "$ref": "https://hearthcode.dev/schemas/color-system/common.schema.json#/definitions/nonEmptyString"
        },
        "right": {
          "$ref": "https://hearthcode.dev/schemas/color-system/common.schema.json#/definitions/nonEmptyString"
        }
      }
    },
    "softRoleAdjustment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "factor",
        "maxChroma",
        "lightnessLift"
      ],
      "properties": {
        "factor": {
          "type": "number"
        },
        "maxChroma": {
          "type": "number"
        },
        "lightnessLift": {
          "type": "number"
        }
      }
    },
    "assetMixExpr": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "a",
        "b",
        "t"
      ],
      "properties": {
        "type": {
          "const": "mix"
        },
        "a": {
          "$ref": "#/definitions/assetColorExpr"
        },
        "b": {
          "$ref": "#/definitions/assetColorExpr"
        },
        "t": {
          "type": "number"
        }
      }
    },
    "assetColorExpr": {
      "anyOf": [
        {
          "$ref": "https://hearthcode.dev/schemas/color-system/common.schema.json#/definitions/nonEmptyString"
        },
        {
          "$ref": "#/definitions/assetMixExpr"
        }
      ]
    },
    "assetVarExpr": {
      "anyOf": [
        {
          "$ref": "#/definitions/assetColorExpr"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "color",
            "value"
          ],
          "properties": {
            "type": {
              "const": "alpha"
            },
            "color": {
              "$ref": "#/definitions/assetColorExpr"
            },
            "value": {
              "type": "number"
            }
          }
        }
      ]
    }
  },
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "lightPolarityRoleOptimization": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "$ref": "#/definitions/polarityRoleRule"
        }
      }
    },
    "globalSeparationTargetByVariant": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/separationTarget"
      }
    },
    "globalSeparationToleranceByVariant": {
      "$ref": "#/definitions/variantNumberMap"
    },
    "globalSeparationBoostProfileByVariant": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/boostProfile"
      }
    },
    "lightReadabilityCalibration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default",
        "byRole"
      ],
      "properties": {
        "default": {
          "$ref": "#/definitions/calibrationProfile"
        },
        "byRole": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/calibrationProfile"
          }
        }
      }
    },
    "lightCoolRoleSoften": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "factorByRole": {
            "$ref": "#/definitions/roleNumberMap"
          },
          "maxChromaByRole": {
            "$ref": "#/definitions/roleNullableNumberMap"
          }
        }
      }
    },
    "globalSeparationRoleProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "baselineDeltaE",
        "boostFactorByRole",
        "lightnessLiftByRole"
      ],
      "properties": {
        "baselineDeltaE": {
          "type": "number"
        },
        "boostFactorByRole": {
          "$ref": "#/definitions/roleNumberMap"
        },
        "lightnessLiftByRole": {
          "$ref": "#/definitions/roleNumberMap"
        }
      }
    },
    "lightPolaritySearchProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hueStep",
        "chromaScales",
        "lightnessShifts",
        "candidateMinL",
        "candidateMaxL",
        "candidateMinC",
        "candidateMaxC",
        "metricRatioCap",
        "preferredDistanceRatioCap",
        "scoreWeights",
        "minImprovement"
      ],
      "properties": {
        "hueStep": {
          "type": "number"
        },
        "chromaScales": {
          "$ref": "https://hearthcode.dev/schemas/color-system/common.schema.json#/definitions/numberArray"
        },
        "lightnessShifts": {
          "$ref": "https://hearthcode.dev/schemas/color-system/common.schema.json#/definitions/numberArray"
        },
        "candidateMinL": {
          "type": "number"
        },
        "candidateMaxL": {
          "type": "number"
        },
        "candidateMinC": {
          "type": "number"
        },
        "candidateMaxC": {
          "type": "number"
        },
        "metricRatioCap": {
          "type": "number"
        },
        "preferredDistanceRatioCap": {
          "type": "number"
        },
        "scoreWeights": {
          "$ref": "#/definitions/scoreWeights"
        },
        "minImprovement": {
          "type": "number"
        }
      }
    },
    "globalSeparationDeficitProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ratioFloorMedian",
        "ratioFloorP25",
        "ratioFloorP10",
        "minNeededFactor"
      ],
      "properties": {
        "ratioFloorMedian": {
          "type": "number"
        },
        "ratioFloorP25": {
          "type": "number"
        },
        "ratioFloorP10": {
          "type": "number"
        },
        "minNeededFactor": {
          "type": "number"
        }
      }
    },
    "lightReadabilitySearchProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scaleStep",
        "driftDivisor",
        "lightnessPenaltyDivisor"
      ],
      "properties": {
        "scaleStep": {
          "type": "number"
        },
        "driftDivisor": {
          "type": "number"
        },
        "lightnessPenaltyDivisor": {
          "type": "number"
        }
      }
    },
    "telemetryProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "readabilityDriftWarningDeltaE"
      ],
      "properties": {
        "readabilityDriftWarningDeltaE": {
          "type": "number"
        }
      }
    },
    "pairSeparationGates": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/pairGate"
      }
    },
    "interactionStateBudget": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/interactionBudget"
      }
    },
    "darkSoftPerceptionGuard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "function",
        "warmRoles",
        "warmAverageMinSaturation",
        "minSaturationByRole"
      ],
      "properties": {
        "function": {
          "$ref": "#/definitions/perceptionGuardFunction"
        },
        "warmRoles": {
          "$ref": "https://hearthcode.dev/schemas/color-system/common.schema.json#/definitions/stringArray"
        },
        "warmAverageMinSaturation": {
          "type": "number"
        },
        "minSaturationByRole": {
          "$ref": "#/definitions/roleNumberMap"
        }
      }
    },
    "roleLaneProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "coolHueBandByVariant",
        "nearForegroundDeltaEByVariant",
        "criticalPairDeltaEByVariant",
        "warmHueBandByVariant",
        "warmGamutGuard",
        "warmExposureProfile"
      ],
      "properties": {
        "coolHueBandByVariant": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/definitions/warmHueRule"
            }
          }
        },
        "nearForegroundDeltaEByVariant": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/definitions/nearForegroundRule"
            }
          }
        },
        "criticalPairDeltaEByVariant": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": {
              "type": "number"
            }
          }
        },
        "warmHueBandByVariant": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/definitions/warmHueRule"
            }
          }
        },
        "warmGamutGuard": {
          "$ref": "#/definitions/warmGamutGuard"
        },
        "warmExposureProfile": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "languageMixWeights",
            "roleFrequencyByLanguage",
            "saliencyByRole",
            "variantTuning"
          ],
          "properties": {
            "languageMixWeights": {
              "$ref": "#/definitions/roleNumberMap"
            },
            "roleFrequencyByLanguage": {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/definitions/roleNumberMap"
              }
            },
            "saliencyByRole": {
              "$ref": "#/definitions/roleNumberMap"
            },
            "variantTuning": {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/definitions/variantTuningProfile"
              }
            }
          }
        }
      }
    },
    "siteDocsProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "semanticRows",
        "snapshotRatios"
      ],
      "properties": {
        "semanticRows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/siteDocRow"
          }
        },
        "snapshotRatios": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/snapshotRatio"
          }
        }
      }
    },
    "softRoleChromaBudget": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "$ref": "#/definitions/softRoleAdjustment"
        }
      }
    },
    "siteAssetMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "derivedColors"
      ],
      "properties": {
        "derivedColors": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/assetColorExpr"
          }
        },
        "groups": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "propertyNames": {
              "pattern": "^--"
            },
            "additionalProperties": {
              "$ref": "#/definitions/assetVarExpr"
            }
          }
        },
        "vars": {
          "type": "object",
          "propertyNames": {
            "pattern": "^--"
          },
          "additionalProperties": {
            "$ref": "#/definitions/assetVarExpr"
          }
        }
      },
      "anyOf": [
        {
          "required": [
            "groups"
          ]
        },
        {
          "required": [
            "vars"
          ]
        }
      ]
    }
  }
}
