{
  "schemaVersion": 1,
  "description": "Migrated VS Code workbench chrome bindings sourced from abstract surfaces and interaction primitives. These bindings cover the highest-signal platform colors while token scope baselines remain temporary migration anchors.",
  "bindings": [
    { "key": "editor.background", "surface": "canvas" },
    { "key": "editor.foreground", "surface": "ink" },
    { "key": "editor.lineHighlightBackground", "interaction": "lineEmphasis" },
    { "key": "editor.selectionBackground", "interaction": "selection" },
    { "key": "editor.selectionHighlightBackground", "interaction": "selection", "alphaScale": 0.5 },
    { "key": "editor.wordHighlightBackground", "interaction": "selection", "alphaScale": 0.62 },
    { "key": "editor.findMatchBackground", "interaction": "tabEmphasis", "alpha": 0.21 },
    { "key": "editor.findMatchHighlightBackground", "interaction": "tabEmphasis", "alpha": 0.10 },
    { "key": "editorLineNumber.foreground", "surface": "gutter" },
    { "key": "editorCursor.foreground", "interaction": "cursor" },
    { "key": "editorCursor.background", "surface": "canvas" },
    { "key": "sideBar.background", "surface": "sidebar" },
    { "key": "sideBar.border", "surface": "border" },
    { "key": "activityBarBadge.background", "interaction": "tabEmphasis" },
    { "key": "statusBar.background", "interaction": "status" },
    { "key": "statusBarItem.hoverBackground", "interaction": "tabEmphasis", "alpha": 0.15 },
    { "key": "statusBarItem.activeBackground", "interaction": "tabEmphasis", "alpha": 0.20 },
    { "key": "titleBar.activeBackground", "surface": "sidebar" },
    { "key": "titleBar.border", "surface": "border" },
    { "key": "tab.activeBackground", "surface": "canvas" },
    { "key": "tab.activeBorder", "interaction": "tabEmphasis" },
    { "key": "tab.inactiveBackground", "surface": "sidebar" },
    { "key": "tab.border", "surface": "border" },
    { "key": "editorGroupHeader.tabsBackground", "surface": "sidebar" },
    { "key": "editorGroupHeader.tabsBorder", "surface": "border" },
    { "key": "panel.background", "surface": "sidebar" },
    { "key": "panel.border", "surface": "border" },
    { "key": "panelTitle.activeBorder", "interaction": "tabEmphasis" },
    { "key": "terminal.background", "surface": "canvas" },
    { "key": "terminal.foreground", "surface": "ink" },
    { "key": "terminalCursor.foreground", "interaction": "cursor" },
    { "key": "input.background", "surface": "panel" },
    { "key": "inputOption.activeBorder", "interaction": "tabEmphasis" },
    { "key": "inputOption.activeBackground", "interaction": "selection", "alphaScale": 0.46 },
    { "key": "dropdown.background", "surface": "panel" },
    { "key": "button.background", "interaction": "tabEmphasis" },
    { "key": "list.hoverBackground", "interaction": "listHover" },
    { "key": "list.highlightForeground", "interaction": "tabEmphasis" },
    { "key": "badge.background", "interaction": "tabEmphasis" },
    { "key": "progressBar.background", "interaction": "tabEmphasis" },
    { "key": "focusBorder", "interaction": "focusRing" },
    { "key": "selection.background", "interaction": "selection", "alphaScale": 1.0 },
    { "key": "notifications.background", "surface": "panel" },
    { "key": "notificationLink.foreground", "interaction": "tabEmphasis" }
  ]
}
