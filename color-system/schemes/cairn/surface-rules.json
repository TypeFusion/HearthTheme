{
  "schemaVersion": 2,
  "description": "Abstract surface anchors for CairnCode. Anchor values stay sparse; surrounding layers derive from them before any platform contract is applied.",
  "surfaces": {
    "canvas": {
      "description": "Primary atmospheric canvas anchor.",
      "source": {
        "type": "foundation",
        "family": "ground",
        "tone": "base"
      }
    },
    "ink": {
      "description": "Readable carrier ink anchor for long sessions.",
      "source": {
        "type": "foundation",
        "family": "carrier",
        "tone": "base"
      }
    },
    "panel": {
      "description": "Raised document substrate mixed up from canvas toward ink.",
      "source": {
        "type": "surface",
        "id": "canvas"
      },
      "derive": {
        "mix": {
          "with": {
            "type": "surface",
            "id": "ink"
          },
          "tFromVariantKnob": "surfaceMix.panelLift"
        }
      }
    },
    "gutter": {
      "description": "Quiet numeric gutter derived as a mid-band between canvas and ink.",
      "source": {
        "type": "surface",
        "id": "canvas"
      },
      "derive": {
        "mix": {
          "with": {
            "type": "surface",
            "id": "ink"
          },
          "tFromVariantKnob": "surfaceMix.gutterBand"
        }
      }
    },
    "sidebar": {
      "description": "Sheltering shell anchor for navigation and chrome.",
      "source": {
        "type": "foundation",
        "family": "shell",
        "tone": "base"
      }
    },
    "border": {
      "description": "Structural edge derived from the same canvas-ink band, but kept quieter than gutter.",
      "source": {
        "type": "surface",
        "id": "canvas"
      },
      "derive": {
        "mix": {
          "with": {
            "type": "surface",
            "id": "ink"
          },
          "tFromVariantKnob": "surfaceMix.borderBand"
        }
      }
    }
  }
}
