{
  "schemaVersion": 1,
  "description": "Abstract interface tones for CairnCode. These govern shell ink hierarchy, on-accent contrast, and navigation fills before any platform token mapping.",
  "interfaces": {
    "shellInk": {
      "description": "Primary readable ink for active tabs, fields, and shell labels.",
      "source": {
        "type": "literal",
        "values": {
          "dark": "#d1c9c0",
          "darkSoft": "#cbc4bc",
          "light": "#31271f",
          "lightSoft": "#4b4139"
        }
      }
    },
    "supportInk": {
      "description": "Readable supporting shell ink for unfocused active items and general navigation copy.",
      "source": {
        "type": "interface",
        "id": "shellInk"
      },
      "derive": {
        "mix": {
          "with": {
            "type": "surface",
            "id": "sidebar"
          },
          "tFromVariantKnob": "interfaceMix.supportInk"
        }
      }
    },
    "mutedInk": {
      "description": "Secondary shell ink for inactive tabs, section titles, and quiet chrome labels.",
      "source": {
        "type": "interface",
        "id": "shellInk"
      },
      "derive": {
        "mix": {
          "with": {
            "type": "surface",
            "id": "sidebar"
          },
          "tFromVariantKnob": "interfaceMix.mutedInk"
        }
      }
    },
    "subtleInk": {
      "description": "Dormant shell ink for placeholders and inactive iconography.",
      "source": {
        "type": "interface",
        "id": "mutedInk"
      },
      "derive": {
        "mix": {
          "with": {
            "type": "surface",
            "id": "sidebar"
          },
          "tFromVariantKnob": "interfaceMix.subtleInk"
        }
      }
    },
    "onAccentInk": {
      "description": "Readable inverse ink placed on accent and badge fills.",
      "source": {
        "type": "literal",
        "values": {
          "dark": "#171412",
          "darkSoft": "#1d1916",
          "light": "#ffffff",
          "lightSoft": "#ffffff"
        }
      }
    },
    "shellRaised": {
      "description": "Raised shell substrate for secondary buttons and bounded form controls.",
      "source": {
        "type": "surface",
        "id": "sidebar"
      },
      "derive": {
        "mix": {
          "with": {
            "type": "interface",
            "id": "shellInk"
          },
          "tFromVariantKnob": "interfaceMix.shellRaised"
        }
      }
    },
    "navActiveFill": {
      "description": "Selected navigation fill for active lists and focused rows.",
      "source": {
        "type": "surface",
        "id": "sidebar"
      },
      "derive": {
        "mix": {
          "with": {
            "type": "interface",
            "id": "shellInk"
          },
          "tFromVariantKnob": "interfaceMix.navActiveFill"
        }
      }
    },
    "navInactiveFill": {
      "description": "Softer navigation fill for inactive selection states and supporting hover groups.",
      "source": {
        "type": "surface",
        "id": "sidebar"
      },
      "derive": {
        "mix": {
          "with": {
            "type": "interface",
            "id": "shellInk"
          },
          "tFromVariantKnob": "interfaceMix.navInactiveFill"
        }
      }
    },
    "shellBand": {
      "description": "Intermediate shell band for section headers and grouped chrome strata.",
      "source": {
        "type": "foundation",
        "family": "shell",
        "tone": "lift"
      }
    },
    "accentHoverFill": {
      "description": "Hover-stage accent fill for buttons and raised controls.",
      "source": {
        "type": "literal",
        "values": {
          "dark": "#c18d62",
          "darkSoft": "#b48d70",
          "light": "#9f6c42",
          "lightSoft": "#ad7d59"
        }
      }
    },
    "onStatusInk": {
      "description": "Readable ink placed on persistent status surfaces.",
      "source": {
        "type": "literal",
        "values": {
          "dark": "#efe6db",
          "darkSoft": "#e8dfd5",
          "light": "#faf1e8",
          "lightSoft": "#eee4db"
        }
      }
    },
    "navActiveInk": {
      "description": "Readable ink placed on active navigation fills.",
      "source": {
        "type": "literal",
        "values": {
          "dark": "#e3d9cd",
          "darkSoft": "#ddd2c7",
          "light": "#31271f",
          "lightSoft": "#4b4139"
        }
      }
    }
  }
}
