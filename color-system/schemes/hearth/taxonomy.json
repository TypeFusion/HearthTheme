{
  "schemaVersion": 1,
  "description": "Machine-readable abstract taxonomy for HearthCode. This groups families, semantic roles, surfaces, interactions, and variants without referencing any platform token names.",
  "families": {
    "environment": ["ground", "carrier", "shell"],
    "signalWarmth": ["ember", "cedar", "terracotta"],
    "structuralWarmth": ["brass", "leather", "ochre"],
    "coolAnchor": ["mineral"],
    "quietSupport": ["ash", "olive", "moss", "chalk"]
  },
  "roles": {
    "signal": ["keyword", "tag", "number"],
    "structure": ["function", "method", "type", "property", "operator"],
    "reading": ["string", "variable", "parameter", "comment"]
  },
  "surfaces": {
    "primary": ["canvas", "ink", "panel"],
    "support": ["sidebar", "gutter", "border"]
  },
  "interactions": {
    "persistent": ["cursor", "status", "tabEmphasis"],
    "contextual": ["selection", "focusRing", "lineEmphasis", "listHover"]
  },
  "feedback": {
    "guidance": ["note", "info"],
    "outcome": ["success", "warning", "error"]
  },
  "variants": {
    "core": ["dark", "light"],
    "soft": ["darkSoft", "lightSoft"]
  }
}
