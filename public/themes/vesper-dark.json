    "tokenColors": [
        {
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#6a5e48",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "keyword",
                "storage.type",
                "storage.modifier",
                "keyword.control"
            ],
            "settings": {
                "foreground": "#cc8855",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "keyword.operator",
                "keyword.operator.assignment"
            ],
            "settings": {
                "foreground": "#a87848",
                "fontStyle": ""
            }
        },
        {
            "scope": [
                "entity.name.function",
                "support.function",
                "meta.function-call.generic"
            ],
            "settings": {
                "foreground": "#ddb86a"
            }
        },
        {
            "scope": [
                "string",
                "string.quoted",
                "string.template",
                "string.regexp"
            ],
            "settings": {
                "foreground": "#90aa78"
            }
        },
        {
            "scope": [
                "constant.numeric",
                "constant.language.boolean",
                "constant.language.null",
                "constant.language.undefined"
            ],
            "settings": {
                "foreground": "#cc8868"
            }
        },
        {
            "scope": [
                "entity.name.type",
                "entity.name.class",
                "support.type",
                "support.class"
            ],
            "settings": {
                "foreground": "#c8a06a",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "variable",
                "variable.other.readwrite"
            ],
            "settings": {
                "foreground": "#bfb298"
            }
        },
        {
            "scope": [
                "variable.other.property",
                "support.type.property-name",
                "meta.object-literal.key"
            ],
            "settings": {
                "foreground": "#c0a070"
            }
        },
        {
            "scope": [
                "entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#c8a06a"
            }
        },
        {
            "scope": [
                "entity.name.tag",
                "punctuation.definition.tag"
            ],
            "settings": {
                "foreground": "#cc8855"
            }
        },
        {
            "scope": [
                "meta.decorator",
                "punctuation.decorator"
            ],
            "settings": {
                "foreground": "#ddb86a",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "punctuation",
                "meta.brace"
            ],
            "settings": {
                "foreground": "#8a7e6a"
            }
        },
        {
            "scope": [
                "constant.other.color",
                "support.constant"
            ],
            "settings": {
                "foreground": "#cc8868"
            }
        },
        {
            "scope": [
                "markup.heading"
            ],
            "settings": {
                "foreground": "#ddb86a",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "markup.bold"
            ],
            "settings": {
                "foreground": "#cc8855",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "markup.italic"
            ],
            "settings": {
                "foreground": "#c8a06a",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "markup.inline.raw",
                "markup.fenced_code"
            ],
            "settings": {
                "foreground": "#90aa78"
            }
        },
        {
            "scope": [
                "markup.underline.link"
            ],
            "settings": {
                "foreground": "#90aa78"
            }
        },
        {
            "scope": [
                "invalid.deprecated"
            ],
            "settings": {
                "foreground": "#c06050",
                "fontStyle": "strikethrough"
            }
        },
        {
            "scope": [
                "invalid.illegal"
            ],
            "settings": {
                "foreground": "#c06050",
                "fontStyle": "underline"
            }
        }
    ],
    "semanticHighlighting": true,
    "semanticTokenColors": {
        "variable": "#bfb298",
        "variable.readonly": "#c8a06a",
        "property": "#c0a070",
        "property.readonly": "#c8a06a",
        "function": "#ddb86a",
        "method": "#ddb86a",
        "class": {
            "foreground": "#c8a06a",
            "fontStyle": "italic"
        },
        "interface": {
            "foreground": "#c8a06a",
            "fontStyle": "italic"
        },
        "type": {
            "foreground": "#c8a06a",
            "fontStyle": "italic"
        },
        "typeParameter": {
            "foreground": "#c8a06a",
            "fontStyle": "italic"
        },
        "enum": {
            "foreground": "#c8a06a",
            "fontStyle": "italic"
        },
        "enumMember": "#cc8868",
        "namespace": "#d0c4aa",
        "keyword": {
            "foreground": "#cc8855",
            "fontStyle": "bold"
        },
        "parameter": "#bfb298",
        "decorator": {
            "foreground": "#ddb86a",
            "fontStyle": "italic"
        }
    }
}