    "tokenColors": [
        {
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#897e71",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "keyword",
                "storage.type",
                "storage.modifier",
                "keyword.control"
            ],
            "settings": {
                "foreground": "#a36050",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "keyword.operator",
                "keyword.operator.assignment"
            ],
            "settings": {
                "foreground": "#776859",
                "fontStyle": ""
            }
        },
        {
            "scope": [
                "meta.function-call entity.name.function",
                "meta.function-call.js entity.name.function.js",
                "meta.function-call.ts entity.name.function.ts",
                "meta.function-call.py entity.name.function.py",
                "meta.function-call.python entity.name.function.python",
                "meta.function-call.go entity.name.function.go",
                "meta.function-call.rust entity.name.function.rust",
                "meta.method-call entity.name.function",
                "meta.method-call.js entity.name.function.js",
                "meta.method-call.ts entity.name.function.ts",
                "meta.method-call.py entity.name.function.py",
                "meta.method-call.python entity.name.function.python",
                "meta.method-call.go entity.name.function.go",
                "meta.method-call.rust entity.name.function.rust"
            ],
            "settings": {
                "foreground": "#866452"
            }
        },
        {
            "scope": [
                "entity.name.function",
                "support.function",
                "meta.function-call.generic"
            ],
            "settings": {
                "foreground": "#6a767c"
            }
        },
        {
            "scope": [
                "entity.name.function.member",
                "entity.name.function.member.python",
                "entity.name.function.member.go",
                "entity.name.function.member.rust",
                "variable.other.property",
                "variable.other.member",
                "meta.property-name",
                "support.type.property-name"
            ],
            "settings": {
                "foreground": "#676b53"
            }
        },
        {
            "scope": [
                "string",
                "string.quoted",
                "string.template",
                "string.regexp"
            ],
            "settings": {
                "foreground": "#7e8676"
            }
        },
        {
            "scope": [
                "constant.numeric",
                "constant.language.boolean",
                "constant.language.null",
                "constant.language.undefined"
            ],
            "settings": {
                "foreground": "#b17d56"
            }
        },
        {
            "scope": [
                "entity.name.type",
                "entity.name.class",
                "storage.type.java",
                "storage.type.primitive.java",
                "entity.name.struct.rust",
                "entity.name.type.class",
                "support.type",
                "support.type.builtin",
                "support.class"
            ],
            "settings": {
                "foreground": "#8a825b",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "variable",
                "variable.other.readwrite",
                "variable.other.constant"
            ],
            "settings": {
                "foreground": "#645447"
            }
        },
        {
            "scope": [
                "meta.object-literal.key"
            ],
            "settings": {
                "foreground": "#986a51"
            }
        },
        {
            "scope": [
                "entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#986743"
            }
        },
        {
            "scope": [
                "entity.name.tag",
                "punctuation.definition.tag"
            ],
            "settings": {
                "foreground": "#814f42"
            }
        },
        {
            "scope": [
                "meta.decorator",
                "punctuation.decorator"
            ],
            "settings": {
                "foreground": "#9b6734",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "punctuation",
                "meta.brace"
            ],
            "settings": {
                "foreground": "#847354"
            }
        },
        {
            "scope": [
                "constant.other.color",
                "support.constant"
            ],
            "settings": {
                "foreground": "#b17d56"
            }
        },
        {
            "scope": [
                "markup.heading"
            ],
            "settings": {
                "foreground": "#966839",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "markup.bold"
            ],
            "settings": {
                "foreground": "#b05e4b",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "markup.italic"
            ],
            "settings": {
                "foreground": "#9c663a",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "markup.inline.raw",
                "markup.fenced_code"
            ],
            "settings": {
                "foreground": "#3f8046"
            }
        },
        {
            "scope": [
                "markup.underline.link"
            ],
            "settings": {
                "foreground": "#3f8046"
            }
        },
        {
            "scope": [
                "invalid.deprecated"
            ],
            "settings": {
                "foreground": "#ad5a4e",
                "fontStyle": "strikethrough"
            }
        },
        {
            "scope": [
                "invalid.illegal"
            ],
            "settings": {
                "foreground": "#a85d51",
                "fontStyle": "underline"
            }
        }
    ],
    "semanticHighlighting": true,
    "semanticTokenColors": {
        "variable": "#645447",
        "variable.readonly": "#9c663a",
        "property": "#676b53",
        "property.readonly": "#9d6633",
        "function": "#6a767c",
        "method": "#866452",
        "function.defaultLibrary": "#866452",
        "method.defaultLibrary": "#866452",
        "class": {
            "foreground": "#8a825b",
            "fontStyle": "italic"
        },
        "interface": {
            "foreground": "#8a825b",
            "fontStyle": "italic"
        },
        "type": {
            "foreground": "#8a825b",
            "fontStyle": "italic"
        },
        "type.defaultLibrary": {
            "foreground": "#8a825b",
            "fontStyle": "italic"
        },
        "typeParameter": {
            "foreground": "#8a825b",
            "fontStyle": "italic"
        },
        "enum": {
            "foreground": "#8a825b",
            "fontStyle": "italic"
        },
        "enumMember": "#b17d56",
        "namespace": "#8a6f4e",
        "keyword": {
            "foreground": "#a36050",
            "fontStyle": "bold"
        },
        "parameter": "#6f5c4c",
        "variable.defaultLibrary": "#9b6734",
        "decorator": {
            "foreground": "#9b6734",
            "fontStyle": "italic"
        }
    }
}
